---
/**
 * src/pages/clients.astro
 * Clients — Global reach, industries served, client logos, certifications.
 */
import Layout from '../layouts/Layout.astro';

const clients = [
  'Boohoo', 'Closure', 'Yours Clothing', 'Pull&Bear',
  'Forever Club', 'Daisy Street', 'Marshall Artist', 'Threadbare', 'Helme',
];

const certifications = [
  { name: 'BCI', full: 'Better Cotton Initiative' },
  { name: 'GOTS', full: 'Global Organic Textile Standard' },
  { name: 'OCS', full: 'Organic Content Standard' },
  { name: 'SEDEX', full: 'Supplier Ethical Data Exchange' },
  { name: 'Higg Index', full: 'Sustainable Apparel Coalition' },
  { name: 'RCS', full: 'Recycled Claim Standard' },
  { name: 'GRS', full: 'Global Recycled Standard' },
  { name: 'ISO 9001:2015', full: 'Quality Management Systems' },
];

const industries = [
  {
    title: 'International Fashion Brands',
    desc: 'Fast fashion and premium fashion labels requiring high-volume, trend-driven production.',
    icon: 'fashion',
  },
  {
    title: 'Sportswear & Activewear',
    desc: 'Performance garments with moisture-wicking, stretch, and durability requirements.',
    icon: 'sport',
  },
  {
    title: "Children's Apparel",
    desc: 'Safe, skin-friendly kids\' wear manufactured with certified non-toxic dyes and processes.',
    icon: 'kids',
  },
  {
    title: 'Corporate Apparel',
    desc: 'Professional uniforms, polo shirts, and branded workwear for corporate clients.',
    icon: 'corporate',
  },
];
---

<Layout
  title="Our Clients"
  description="Discover the global brands that trust Reve Stitching — serving international fashion, sportswear, children's apparel, and corporate sectors."
>

  <!-- ━━━━━━ HERO ━━━━━━ -->
  <section class="relative py-24 lg:py-32 overflow-hidden bg-surface" aria-label="Clients hero">
    <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px]"></div>

    <div class="container-main section-padding relative z-10 text-center">
      <span class="section-label justify-center" data-animate="fade-up">Our Clients</span>
      <h1 class="heading-display mb-6 max-w-3xl mx-auto" data-animate="fade-up" data-delay="0.1">
        Trusted by <span class="text-gradient">Global Brands</span>
      </h1>
      <p class="text-body max-w-2xl mx-auto" data-animate="fade-up" data-delay="0.2">
        From high-street fashion to premium activewear, we partner with brands across the world to deliver quality garments at scale.
      </p>
    </div>
  </section>

  <!-- ━━━━━━ GLOBAL MAP SECTION ━━━━━━ -->
  <section class="py-24 lg:py-32 bg-white" aria-labelledby="global-heading">
    <div class="container-main section-padding">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Map Image -->
        <div class="relative" data-animate="fade-right">
          <div class="relative rounded-3xl overflow-hidden bg-surface border border-border p-8">
            <!-- Simplified SVG world map placeholder -->
            <div class="aspect-[16/10] flex items-center justify-center">
              <svg viewBox="0 0 800 400" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Simplified world outline -->
                <ellipse cx="400" cy="200" rx="380" ry="180" stroke="#dcfce7" stroke-width="1" fill="none"/>
                <ellipse cx="400" cy="200" rx="280" ry="130" stroke="#dcfce7" stroke-width="0.5" fill="none" stroke-dasharray="4 4"/>
                <ellipse cx="400" cy="200" rx="160" ry="75" stroke="#dcfce7" stroke-width="0.5" fill="none" stroke-dasharray="4 4"/>
                <line x1="20" y1="200" x2="780" y2="200" stroke="#dcfce7" stroke-width="0.5" stroke-dasharray="4 4"/>
                <line x1="400" y1="20" x2="400" y2="380" stroke="#dcfce7" stroke-width="0.5" stroke-dasharray="4 4"/>

                <!-- Location pins -->
                <!-- Faisalabad (Origin) -->
                <circle cx="510" cy="170" r="8" fill="#166534"/>
                <circle cx="510" cy="170" r="16" fill="#166534" fill-opacity="0.2"/>
                <circle cx="510" cy="170" r="24" fill="#166534" fill-opacity="0.08"/>
                <text x="510" y="155" text-anchor="middle" class="text-[10px] fill-primary font-semibold">HQ</text>

                <!-- UK -->
                <circle cx="350" cy="130" r="5" fill="#22c55e"/>
                <circle cx="350" cy="130" r="12" fill="#22c55e" fill-opacity="0.15"/>

                <!-- EU -->
                <circle cx="380" cy="145" r="5" fill="#22c55e"/>
                <circle cx="380" cy="145" r="12" fill="#22c55e" fill-opacity="0.15"/>

                <!-- Spain -->
                <circle cx="345" cy="160" r="5" fill="#22c55e"/>
                <circle cx="345" cy="160" r="12" fill="#22c55e" fill-opacity="0.15"/>
              </svg>
            </div>

            <!-- Legend -->
            <div class="flex items-center justify-center gap-6 mt-4">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-primary"></div>
                <span class="text-xs text-zinc-500 font-medium">Headquarters</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-primary-light"></div>
                <span class="text-xs text-zinc-500 font-medium">Client Regions</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div>
          <span class="section-label" data-animate="fade-up">Global Reach</span>
          <h2 id="global-heading" class="heading-headline mb-6" data-animate="fade-up" data-delay="0.1">
            Serving Brands <span class="text-gradient">Worldwide</span>
          </h2>
          <p class="text-body mb-8" data-animate="fade-up" data-delay="0.2">
            From our state-of-the-art facility in Faisalabad, we ship export-quality garments to fashion brands across the United Kingdom, Europe, and beyond. Our strategic location and logistics network ensure timely delivery to any global destination.
          </p>

          <div class="grid grid-cols-2 gap-4" data-animate="fade-up" data-delay="0.3">
            <div class="bg-surface rounded-xl p-5 border border-border">
              <div class="text-2xl font-bold text-primary mb-1">UK</div>
              <div class="text-xs text-zinc-500">Primary Market</div>
            </div>
            <div class="bg-surface rounded-xl p-5 border border-border">
              <div class="text-2xl font-bold text-primary mb-1">EU</div>
              <div class="text-xs text-zinc-500">Growing Market</div>
            </div>
            <div class="bg-surface rounded-xl p-5 border border-border">
              <div class="text-2xl font-bold text-primary mb-1">9+</div>
              <div class="text-xs text-zinc-500">Brand Partners</div>
            </div>
            <div class="bg-surface rounded-xl p-5 border border-border">
              <div class="text-2xl font-bold text-primary mb-1">100%</div>
              <div class="text-xs text-zinc-500">Export Oriented</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ━━━━━━ INDUSTRIES SERVED ━━━━━━ -->
  <section class="py-24 lg:py-32 bg-surface" aria-labelledby="industries-heading">
    <div class="container-main section-padding">
      <div class="text-center mb-16">
        <span class="section-label justify-center" data-animate="fade-up">Industries We Serve</span>
        <h2 id="industries-heading" class="heading-headline mb-5" data-animate="fade-up" data-delay="0.1">
          Sectors We <span class="text-gradient">Specialize</span> In
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-stagger="0.1">
        {industries.map((industry) => (
          <article class="bg-white rounded-2xl p-8 border border-zinc-100 text-center group hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 transition-all duration-500">
            <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-5 group-hover:bg-primary group-hover:scale-110 transition-all duration-300">
              {industry.icon === 'fashion' && (
                <svg class="w-8 h-8 text-primary group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
              )}
              {industry.icon === 'sport' && (
                <svg class="w-8 h-8 text-primary group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/></svg>
              )}
              {industry.icon === 'kids' && (
                <svg class="w-8 h-8 text-primary group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>
              )}
              {industry.icon === 'corporate' && (
                <svg class="w-8 h-8 text-primary group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/></svg>
              )}
            </div>
            <h3 class="text-base font-bold text-zinc-900 mb-2">{industry.title}</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">{industry.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ━━━━━━ CLIENT LOGOS ━━━━━━ -->
  <section class="py-24 lg:py-32 bg-white" aria-labelledby="logos-heading">
    <div class="container-main section-padding">
      <div class="text-center mb-16">
        <span class="section-label justify-center" data-animate="fade-up">Trusted Partners</span>
        <h2 id="logos-heading" class="heading-headline mb-5" data-animate="fade-up" data-delay="0.1">
          Brands We <span class="text-gradient">Work With</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4" data-stagger="0.06">
        {clients.map((client) => (
          <div class="bg-surface rounded-2xl border border-border p-8 flex items-center justify-center aspect-[3/2] group hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all duration-500">
            <span class="text-lg font-bold text-zinc-400 group-hover:text-primary transition-colors duration-300 text-center">
              {client}
            </span>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-zinc-400 mt-8" data-animate="fade-up">
        Replace these text placeholders with your client logos at <code class="text-xs bg-zinc-100 px-2 py-0.5 rounded">/public/images/clients/</code>
      </p>
    </div>
  </section>

  <!-- ━━━━━━ CERTIFICATIONS ━━━━━━ -->
  <section class="py-24 lg:py-32 bg-primary-dark relative overflow-hidden" aria-labelledby="certs-heading">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="container-main section-padding relative z-10">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-bold tracking-[0.2em] uppercase text-primary-light mb-4" data-animate="fade-up">
          <span class="w-8 h-px bg-primary-light"></span>
          Certifications
          <span class="w-8 h-px bg-primary-light"></span>
        </span>
        <h2 id="certs-heading" class="font-serif text-headline text-white mb-5" data-animate="fade-up" data-delay="0.1">
          Certified for Excellence
        </h2>
        <p class="text-green-100/60 max-w-xl mx-auto" data-animate="fade-up" data-delay="0.2">
          Our certifications reflect our unwavering commitment to quality, ethics, and sustainability.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" data-stagger="0.08">
        {certifications.map((cert) => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 text-center hover:bg-white/10 hover:border-white/20 transition-all duration-300">
            <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
            </div>
            <div class="text-lg font-bold text-white mb-1">{cert.name}</div>
            <p class="text-xs text-green-100/50">{cert.full}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ━━━━━━ STATS HIGHLIGHT ━━━━━━ -->
  <section class="py-20 bg-white" aria-label="Key figures">
    <div class="container-main section-padding">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center" data-stagger="0.1">
        {[
          { value: 300000, suffix: '+', label: 'Monthly Garments' },
          { value: 150, suffix: '+', label: 'Modern Machines' },
          { value: 9, suffix: '+', label: 'Brand Partners' },
          { value: 8, suffix: '', label: 'Certifications' },
        ].map((stat) => (
          <div>
            <div class="text-4xl lg:text-5xl font-bold text-primary mb-2" data-counter={stat.value} data-suffix={stat.suffix}>
              {stat.value.toLocaleString()}{stat.suffix}
            </div>
            <div class="text-sm text-zinc-500 font-medium uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>