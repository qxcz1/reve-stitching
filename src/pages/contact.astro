---
/**
 * src/pages/contact.astro
 * Contact — Form, team cards, FAQ accordion, map placeholder.
 */
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

const faqs = [
  {
    question: 'What is your minimum order quantity (MOQ)?',
    answer: 'Our standard MOQ varies by product type, typically ranging from 200-500 pieces per style/color. For initial trial orders, we can be flexible to accommodate new partnerships. Please contact us to discuss your specific requirements.',
  },
  {
    question: 'What quality standards do you maintain?',
    answer: 'We maintain AQL 1.5-4.0 quality standards across every production run. Our SGS-trained quality control team conducts multi-stage inspections — from raw material checks through 14 in-process checkpoints to final garment audit — ensuring consistent quality output.',
  },
  {
    question: 'Are you compliant with international standards?',
    answer: 'Yes. We are fully SEDEX compliant and work within BCI, GOTS, OCS, Higg Index, RCS, GRS, and ISO 9001:2015 certified frameworks. Our ethical manufacturing practices cover worker welfare, environmental sustainability, and supply chain transparency.',
  },
  {
    question: 'What is your production lead time?',
    answer: 'Standard production lead time is 30-45 days from order confirmation, depending on order size, complexity, and fabric availability. Rush orders can be accommodated on a case-by-case basis. We also provide a detailed production timeline before order confirmation.',
  },
  {
    question: 'What fabric types do you work with?',
    answer: 'We work with a diverse range of knitted fabrics including Single Jersey, Double Jersey, Terry Fleece, Lycra Rib, Interlock, and Moisture Management fabrics. We also develop specialized blends such as Lurex Mixed, Burnout Printed, and Modal compositions.',
  },
  {
    question: 'Do you provide samples before bulk production?',
    answer: 'Absolutely. We provide pre-production samples for client approval before commencing bulk production. Sample development typically takes 7-10 business days. We cover up to two rounds of revisions at no additional cost to ensure the sample meets your exact specifications.',
  },
];

const teamContacts = [
  {
    name: 'Haroon Iqbal',
    role: 'Director — Client Relations',
    email: 'haroon@revestitching.com',
    phone: '+92 XXX XXXXXXX',
    image: '/images/team/director-haroon.jpg',
  },
  {
    name: 'Abdul Basit',
    role: 'Director — Operations',
    email: 'abdul.basit@revestitching.com',
    phone: '+92 XXX XXXXXXX',
    image: '/images/team/director-basit.jpg',
  },
];
---

<Layout
  title="Contact Us"
  description="Get in touch with Reve Stitching. Request a quote, discuss your garment manufacturing needs, or schedule a factory visit. We respond within 24 hours."
>

  <!-- ━━━━━━ HERO ━━━━━━ -->
  <section class="relative py-24 lg:py-32 overflow-hidden bg-surface" aria-label="Contact hero">
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px]"></div>

    <div class="container-main section-padding relative z-10 text-center">
      <span class="section-label justify-center" data-animate="fade-up">Contact Us</span>
      <h1 class="heading-display mb-6 max-w-3xl mx-auto" data-animate="fade-up" data-delay="0.1">
        Let's Start a <span class="text-gradient">Conversation</span>
      </h1>
      <p class="text-body max-w-2xl mx-auto" data-animate="fade-up" data-delay="0.2">
        Ready to discuss your next order? Our team responds within 24 hours. Send us your requirements and let's build something great together.
      </p>
    </div>
  </section>

  <!-- ━━━━━━ CONTACT FORM + INFO ━━━━━━ -->
  <section class="py-24 lg:py-32 bg-white" aria-labelledby="form-heading">
    <div class="container-main section-padding">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Left — Form (3 cols) -->
        <div class="lg:col-span-3" data-animate="fade-right">
          <h2 id="form-heading" class="heading-title mb-2">Send Us a Message</h2>
          <p class="text-body-sm mb-8">Fill out the form below and we'll get back to you within 24 hours.</p>

          <form action="#" method="POST" class="space-y-6" aria-label="Contact form">
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-zinc-700 mb-2">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-semibold text-zinc-700 mb-2">Company Name *</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  required
                  placeholder="Your company"
                  class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-semibold text-zinc-700 mb-2">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@company.com"
                  class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-zinc-700 mb-2">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+1 (555) 000-0000"
                  class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none"
                />
              </div>
            </div>

            <div>
              <label for="product" class="block text-sm font-semibold text-zinc-700 mb-2">Product Interest</label>
              <select
                id="product"
                name="product"
                class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white text-zinc-600 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none appearance-none"
              >
                <option value="">Select a product category</option>
                <option value="tshirts">Premium Cotton T-Shirts</option>
                <option value="polos">Corporate Polo Shirts</option>
                <option value="hoodies">Premium Hoodies</option>
                <option value="joggers">Athletic Joggers</option>
                <option value="sweatshirts">Sweatshirts</option>
                <option value="ladies">Ladies' Wear</option>
                <option value="kids">Kids' Wear</option>
                <option value="specialized">Specialized Fabric Garments</option>
                <option value="other">Other / Custom</option>
              </select>
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="moq" class="block text-sm font-semibold text-zinc-700 mb-2">Estimated Quantity</label>
                <input
                  type="text"
                  id="moq"
                  name="moq"
                  placeholder="e.g., 5,000 units"
                  class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none"
                />
              </div>
              <div>
                <label for="timeline" class="block text-sm font-semibold text-zinc-700 mb-2">Target Timeline</label>
                <input
                  type="text"
                  id="timeline"
                  name="timeline"
                  placeholder="e.g., 6 weeks"
                  class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-zinc-700 mb-2">Message *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Tell us about your project requirements, fabric preferences, customization needs..."
                class="w-full px-4 py-3.5 border border-zinc-200 rounded-xl text-sm bg-white placeholder-zinc-400 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 outline-none resize-y"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full sm:w-auto" data-magnetic>
              Send Inquiry
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>

        <!-- Right — Info Cards (2 cols) -->
        <div class="lg:col-span-2 space-y-6" data-animate="fade-left" data-delay="0.2">

          <!-- Office Info -->
          <div class="bg-surface rounded-2xl p-8 border border-border">
            <h3 class="text-lg font-bold text-zinc-900 mb-5">Our Office</h3>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-800">Address</p>
                  <p class="text-sm text-zinc-500 mt-1">Chak No. 196/R.B, Ghona Road,<br/>Faisalabad (38000), Pakistan</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-800">Email</p>
                  <a href="mailto:haroon@revestitching.com" class="text-sm text-primary hover:text-primary-light transition-colors block mt-1">haroon@revestitching.com</a>
                  <a href="mailto:abdul.basit@revestitching.com" class="text-sm text-primary hover:text-primary-light transition-colors block">abdul.basit@revestitching.com</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-800">Working Hours</p>
                  <p class="text-sm text-zinc-500 mt-1">Monday – Saturday: 8 AM – 6 PM<br/>Sunday: Closed</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Team Contact Cards -->
          {teamContacts.map((person) => (
            <div class="bg-white rounded-2xl p-6 border border-zinc-100 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-14 h-14 rounded-xl overflow-hidden bg-zinc-100 shrink-0">
                  <img
                    src={person.image}
                    alt={person.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div>
                  <h4 class="font-bold text-zinc-900">{person.name}</h4>
                  <p class="text-xs text-primary font-semibold">{person.role}</p>
                </div>
              </div>
              <div class="space-y-2">
                <a href={`mailto:${person.email}`} class="flex items-center gap-2 text-sm text-zinc-600 hover:text-primary transition-colors">
                  <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                  {person.email}
                </a>
                <a href={`tel:${person.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-sm text-zinc-600 hover:text-primary transition-colors">
                  <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                  {person.phone}
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ━━━━━━ MAP PLACEHOLDER ━━━━━━ -->
  <section class="bg-zinc-100" aria-label="Location map">
    <div class="w-full h-[400px] relative overflow-hidden">
      <!-- Replace with a real Google Maps embed or Mapbox -->
      <div class="absolute inset-0 bg-surface flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 text-primary/20 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
          <p class="text-sm text-zinc-400 font-medium">
            Google Maps Embed — Chak No. 196/R.B, Ghona Road, Faisalabad
          </p>
          <p class="text-xs text-zinc-300 mt-1">
            Replace this div with an <code>&lt;iframe&gt;</code> from Google Maps
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ━━━━━━ FAQ ━━━━━━ -->
  <section class="py-24 lg:py-32 bg-white" aria-labelledby="faq-heading">
    <div class="container-main section-padding">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Left — Heading -->
        <div class="lg:col-span-2">
          <span class="section-label" data-animate="fade-up">FAQ</span>
          <h2 id="faq-heading" class="heading-headline mb-5" data-animate="fade-up" data-delay="0.1">
            Frequently Asked <span class="text-gradient">Questions</span>
          </h2>
          <p class="text-body mb-6" data-animate="fade-up" data-delay="0.2">
            Got questions? We've answered the most common ones below.
            For anything else, don't hesitate to reach out.
          </p>
          <a href="mailto:haroon@revestitching.com" class="btn-outline !text-xs" data-magnetic data-animate="fade-up" data-delay="0.3">
            Ask a Question
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Right — Accordion -->
        <div class="lg:col-span-3">
          <FAQ items={faqs} />
        </div>
      </div>
    </div>
  </section>

</Layout>