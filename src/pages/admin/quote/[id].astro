---
// src/pages/admin/quotes/[id].astro

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabase } from '../../../lib/supabase';
import { getSignedUrl } from '../../../lib/services/storage';
import {
  PRODUCT_NAMES, FABRIC_NAMES, CUSTOMIZATION_NAMES,
  DESTINATION_NAMES, STATUS_META,
  type QuoteRequest, type QuoteStatus,
} from '../../../lib/types/quote';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/quotes');

const supabase = getSupabase();

// ── Handle POST actions (status / notes updates) ──
let flash = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'update-status') {
    const newStatus = formData.get('status') as string;
    const { error } = await supabase
      .from('quote_requests')
      .update({ status: newStatus })
      .eq('id', id);
    flash = error ? `Error: ${error.message}` : `Status updated to "${newStatus}".`;
  }

  if (action === 'update-notes') {
    const notes = formData.get('admin_notes') as string;
    const assignedTo = formData.get('assigned_to') as string;
    const { error } = await supabase
      .from('quote_requests')
      .update({ admin_notes: notes || null, assigned_to: assignedTo || null })
      .eq('id', id);
    flash = error ? `Error: ${error.message}` : 'Notes saved.';
  }
}

// ── Fetch quote ──
const { data: quote, error: fetchError } = await supabase
  .from('quote_requests')
  .select('*')
  .eq('id', id)
  .single();

if (fetchError || !quote) return Astro.redirect('/admin/quotes');

const q = quote as QuoteRequest;
const sm = STATUS_META[q.status as QuoteStatus] || STATUS_META.new;

// ── Signed URLs for files ──
let techPackSignedUrl: string | null = null;
if (q.tech_pack_url) {
  techPackSignedUrl = await getSignedUrl(q.tech_pack_url);
}

const imageSignedUrls: { path: string; url: string }[] = [];
for (const imgPath of (q.reference_images || [])) {
  const signedUrl = await getSignedUrl(imgPath);
  if (signedUrl) imageSignedUrls.push({ path: imgPath, url: signedUrl });
}

// ── Helpers ──
function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    weekday: 'short', day: 'numeric', month: 'long', year: 'numeric',
  });
}

function fileName(path: string): string {
  return path.split('/').pop() || path;
}

const productLabel = PRODUCT_NAMES[q.product_type] || q.product_type;
const fabricLabel  = FABRIC_NAMES[q.fabric_type] || q.fabric_type;
const destLabel    = DESTINATION_NAMES[q.destination] || q.destination;
const customList   = (q.customizations || []).map((c: string) => CUSTOMIZATION_NAMES[c] || c);

// Build mailto link
const mailSubject = encodeURIComponent(`RE: Quote ${q.reference_number} — Reve Stitching`);
const mailBody = encodeURIComponent(
  `Dear ${q.contact_person},\n\nThank you for your quote request (${q.reference_number}) for ${q.quantity} pcs of ${productLabel}.\n\nWe have reviewed your requirements and are pleased to offer the following:\n\n[Your quote details here]\n\nPlease let us know if you have any questions.\n\nBest regards,\nReve Stitching Team`
);
const mailtoHref = `mailto:${q.email}?subject=${mailSubject}&body=${mailBody}`;

const allStatuses: QuoteStatus[] = ['new', 'reviewed', 'quoted', 'converted', 'rejected'];
---

<AdminLayout title={`Quote ${q.reference_number}`}>

  <!-- Flash Message -->
  {flash && (
    <div class:list={[
      "mb-6 rounded-lg p-3 text-sm font-medium",
      flash.startsWith('Error') ? "bg-red-50 text-red-800" : "bg-green-50 text-green-800"
    ]} role="alert">
      {flash}
    </div>
  )}

  <!-- Back + Header -->
  <div class="mb-6">
    <a href="/admin/quotes" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      Back to all quotes
    </a>
  </div>

  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900">{q.reference_number}</h1>
        <span class:list={["rounded-full px-3 py-1 text-xs font-semibold", sm.bg, sm.color]}>
          {sm.label}
        </span>
        {q.is_rush && (
          <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Rush
          </span>
        )}
      </div>
      <p class="mt-1 text-sm text-gray-500">
        Submitted {formatDate(q.created_at)} • {q.company_name}
      </p>
    </div>

    <div class="flex gap-2">
      <a
        href={mailtoHref}
        class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white shadow transition hover:bg-primary-light"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Email Client
      </a>
      <button
        onclick="window.print()"
        class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm transition hover:bg-gray-50"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
        Print
      </button>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="grid gap-6 lg:grid-cols-3">

    <!-- LEFT COL: Details (2/3) -->
    <div class="space-y-6 lg:col-span-2">

      <!-- AI Summary -->
      {q.ai_summary && (
        <div class="rounded-xl border border-primary/20 bg-primary/5 p-6">
          <div class="mb-3 flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-primary/20">
              <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </span>
            <h2 class="text-sm font-bold text-gray-900">AI Analysis</h2>
          </div>
          <p class="text-sm leading-relaxed text-gray-700">{q.ai_summary}</p>
          <div class="mt-4 flex flex-wrap gap-4 text-sm">
            {q.estimated_price_range && (
              <div class="rounded-lg bg-white px-3 py-2 shadow-sm">
                <span class="text-xs text-gray-500">Est. Price</span>
                <p class="font-bold text-primary">{q.estimated_price_range}</p>
              </div>
            )}
            {q.suggested_moq && (
              <div class="rounded-lg bg-white px-3 py-2 shadow-sm">
                <span class="text-xs text-gray-500">Suggested MOQ</span>
                <p class="font-bold text-amber-700">{q.suggested_moq.toLocaleString()} pcs</p>
              </div>
            )}
          </div>
          {q.ai_flags && (
            <div class="mt-3 flex items-start gap-2 rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-800">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <span>{q.ai_flags}</span>
            </div>
          )}
        </div>
      )}

      <!-- Tech Pack Analysis -->
      {q.ai_extracted_data && Object.keys(q.ai_extracted_data).length > 0 && (
        <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
          <div class="mb-4 flex items-center justify-between">
            <h2 class="flex items-center gap-2 text-sm font-bold text-gray-900">
              <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Tech Pack Analysis
            </h2>
            {q.ai_confidence_score !== null && (
              <div class="flex items-center gap-2">
                <div class="h-2 w-32 overflow-hidden rounded-full bg-gray-200">
                  <div 
                    class="h-full rounded-full bg-gradient-to-r from-primary to-primary-light transition-all"
                    style={`width: ${(q.ai_confidence_score * 100).toFixed(0)}%`}
                  ></div>
                </div>
                <span class="text-xs font-medium text-gray-600">
                  {(q.ai_confidence_score * 100).toFixed(0)}%
                </span>
              </div>
            )}
          </div>

          <!-- Extracted Specs -->
          <div class="space-y-3 rounded-lg bg-gray-50 p-4">
            {q.ai_extracted_data.product_type && (
              <div class="flex gap-2 text-sm">
                <span class="min-w-[130px] font-medium text-gray-600">Product Type:</span>
                <span class="text-gray-900">{q.ai_extracted_data.product_type}</span>
              </div>
            )}
            
            {q.ai_extracted_data.fabric_details && (
              <div class="flex gap-2 text-sm">
                <span class="min-w-[130px] font-medium text-gray-600">Fabric:</span>
                <span class="text-gray-900">{q.ai_extracted_data.fabric_details}</span>
              </div>
            )}

            {q.ai_extracted_data.gsm && (
              <div class="flex gap-2 text-sm">
                <span class="min-w-[130px] font-medium text-gray-600">GSM:</span>
                <span class="text-gray-900">{q.ai_extracted_data.gsm}</span>
              </div>
            )}

            {q.ai_extracted_data.colors && q.ai_extracted_data.colors.length > 0 && (
              <div class="flex gap-2 text-sm">
                <span class="min-w-[130px] font-medium text-gray-600">Colors Visible:</span>
                <span class="text-gray-900">{q.ai_extracted_data.colors.join(', ')}</span>
              </div>
            )}

            {q.ai_extracted_data.decorations && q.ai_extracted_data.decorations.length > 0 && (
              <div class="text-sm">
                <span class="font-medium text-gray-600">Decorations:</span>
                <div class="mt-1 space-y-1 text-gray-900">
                  {q.ai_extracted_data.decorations.map((dec: any) => (
                    <div class="flex items-start gap-2">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gray-400"></span>
                      <span><strong>{dec.type}</strong> — {dec.location} — {dec.details}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {q.ai_extracted_data.accessories && q.ai_extracted_data.accessories.length > 0 && (
              <div class="flex gap-2 text-sm">
                <span class="min-w-[130px] font-medium text-gray-600">Accessories:</span>
                <span class="text-gray-900">{q.ai_extracted_data.accessories.join(', ')}</span>
              </div>
            )}
          </div>

          <!-- Missing Information -->
          {q.ai_missing_fields && q.ai_missing_fields.length > 0 && (
            <div class="mt-4">
              <h4 class="mb-2 flex items-center gap-2 text-sm font-semibold text-amber-700">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                Missing Information
              </h4>
              <ul class="space-y-1">
                {q.ai_missing_fields.map((field: string) => (
                  <li class="flex items-start gap-2 text-sm text-amber-600">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-amber-400"></span>
                    <span>{field}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Action Items -->
          {q.action_items && q.action_items.items && q.action_items.items.length > 0 && (
            <div class="mt-4">
              <h4 class="mb-3 flex items-center gap-2 text-sm font-semibold text-gray-900">
                <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                Action Items for Sales Team
              </h4>
              <div class="space-y-2">
                {q.action_items.items.map((item: any) => (
                  <div class="flex items-start gap-3 rounded-lg border border-gray-200 bg-white p-3 transition hover:border-primary/50">
                    <input 
                      type="checkbox" 
                      checked={item.completed}
                      class="mt-0.5 h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary"
                    />
                    <div class="flex-1">
                      <div class="flex items-center gap-2">
                        <span class={`
                          rounded px-2 py-0.5 text-xs font-semibold uppercase
                          ${item.priority === 'high' ? 'bg-red-100 text-red-700' : ''}
                          ${item.priority === 'medium' ? 'bg-yellow-100 text-yellow-700' : ''}
                          ${item.priority === 'low' ? 'bg-gray-100 text-gray-600' : ''}
                        `}>
                          {item.priority}
                        </span>
                        <span class="text-sm font-medium text-gray-900">{item.title}</span>
                      </div>
                      <p class="mt-1 text-xs text-gray-600">{item.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <!-- Contact Card -->
      <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-gray-900">
          <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Contact Information
        </h2>
        <dl class="grid gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
          <div><dt class="text-gray-500">Company</dt><dd class="mt-0.5 font-semibold text-gray-900">{q.company_name}</dd></div>
          <div><dt class="text-gray-500">Contact</dt><dd class="mt-0.5 font-semibold text-gray-900">{q.contact_person}</dd></div>
          <div><dt class="text-gray-500">Email</dt><dd class="mt-0.5"><a href={`mailto:${q.email}`} class="font-medium text-primary hover:underline">{q.email}</a></dd></div>
          <div><dt class="text-gray-500">Phone</dt><dd class="mt-0.5 font-medium text-gray-900">{q.phone || '—'}</dd></div>
        </dl>
      </div>

      <!-- Product & Specs Card -->
      <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-gray-900">
          <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          Product &amp; Specifications
        </h2>
        <dl class="grid gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
          <div><dt class="text-gray-500">Product</dt><dd class="mt-0.5 font-semibold text-gray-900">{productLabel}</dd></div>
          <div><dt class="text-gray-500">Fabric</dt><dd class="mt-0.5 font-medium text-gray-900">{fabricLabel}</dd></div>
          <div><dt class="text-gray-500">GSM</dt><dd class="mt-0.5 font-medium text-gray-900">{q.gsm} g/m²</dd></div>
          <div><dt class="text-gray-500">Quantity</dt><dd class="mt-0.5 text-lg font-bold text-primary">{q.quantity.toLocaleString()} pcs</dd></div>
          <div><dt class="text-gray-500">Sizes</dt><dd class="mt-0.5 font-medium text-gray-900">{(q.sizes || []).join(', ')}</dd></div>
          <div><dt class="text-gray-500">Colors</dt><dd class="mt-0.5 font-medium text-gray-900">{q.color_count}</dd></div>
        </dl>
      </div>

      <!-- Customization Card -->
      {customList.length > 0 && (
        <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
          <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-gray-900">
            <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
            Customizations
          </h2>
          <div class="flex flex-wrap gap-2">
            {customList.map((c: string) => (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800">
                <svg class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {c}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Delivery Card -->
      <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-gray-900">
          <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Delivery &amp; Timeline
        </h2>
        <dl class="grid gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
          <div><dt class="text-gray-500">Target Date</dt><dd class="mt-0.5 font-semibold text-gray-900">{formatDate(q.target_date)}</dd></div>
          <div><dt class="text-gray-500">Destination</dt><dd class="mt-0.5 font-medium text-gray-900">{destLabel}</dd></div>
          <div>
            <dt class="text-gray-500">Sample Required</dt>
            <dd class="mt-0.5 flex items-center gap-1.5 font-medium text-gray-900">
              {q.has_sample ? (
                <>
                  <svg class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Yes
                </>
              ) : 'No'}
            </dd>
          </div>
          <div>
            <dt class="text-gray-500">Rush Order</dt>
            <dd class:list={["mt-0.5 flex items-center gap-1.5 font-medium", q.is_rush ? "text-amber-700" : "text-gray-900"]}>
              {q.is_rush ? (
                <>
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  Yes
                </>
              ) : 'No'}
            </dd>
          </div>
        </dl>
      </div>

      <!-- Customer Notes -->
      {q.notes && (
        <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
          <h2 class="mb-2 flex items-center gap-2 text-sm font-bold text-gray-900">
            <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
            Customer Notes
          </h2>
          <p class="whitespace-pre-wrap text-sm leading-relaxed text-gray-700">{q.notes}</p>
        </div>
      )}

      <!-- Files -->
      {(techPackSignedUrl || imageSignedUrls.length > 0) && (
        <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
          <h2 class="mb-4 flex items-center gap-2 text-sm font-bold text-gray-900">
            <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
            Uploaded Files
          </h2>
          <div class="space-y-2">
            {techPackSignedUrl && (
              <a
                href={techPackSignedUrl}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 rounded-lg border border-gray-200 p-3 text-sm transition hover:bg-gray-50"
              >
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-50 text-red-600">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                </span>
                <div>
                  <p class="font-medium text-gray-900">Tech Pack</p>
                  <p class="text-xs text-gray-500">{fileName(q.tech_pack_url!)}</p>
                </div>
                <span class="ml-auto flex items-center gap-1 text-xs text-primary">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download
                </span>
              </a>
            )}

            {imageSignedUrls.map((img) => (
              <a
                href={img.url}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 rounded-lg border border-gray-200 p-3 text-sm transition hover:bg-gray-50"
              >
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-blue-600">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </span>
                <div>
                  <p class="font-medium text-gray-900">Reference Image</p>
                  <p class="text-xs text-gray-500">{fileName(img.path)}</p>
                </div>
                <span class="ml-auto flex items-center gap-1 text-xs text-primary">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download
                </span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- RIGHT COL: Actions (1/3) -->
    <div class="space-y-6">

      <!-- Status Update -->
      <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
        <h2 class="mb-4 text-sm font-bold text-gray-900">Update Status</h2>
        <form method="POST" class="space-y-3">
          <input type="hidden" name="_action" value="update-status" />
          <select
            name="status"
            class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
          >
            {allStatuses.map((s) => (
              <option value={s} selected={q.status === s}>
                {STATUS_META[s].label}
              </option>
            ))}
          </select>
          <button
            type="submit"
            class="w-full rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white shadow transition hover:bg-primary-light"
          >
            Update Status
          </button>
        </form>
      </div>

      <!-- Admin Notes -->
      <div class="rounded-xl bg-white p-6 shadow ring-1 ring-gray-200">
        <h2 class="mb-4 text-sm font-bold text-gray-900">Internal Notes</h2>
        <form method="POST" class="space-y-3">
          <input type="hidden" name="_action" value="update-notes" />
          <div>
            <label for="assigned_to" class="block text-xs font-medium text-gray-500">Assigned To</label>
            <input
              type="text"
              id="assigned_to"
              name="assigned_to"
              value={q.assigned_to || ''}
              placeholder="e.g. Ali, Sarah…"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
            />
          </div>
          <div>
            <label for="admin_notes" class="block text-xs font-medium text-gray-500">Notes</label>
            <textarea
              id="admin_notes"
              name="admin_notes"
              rows="5"
              placeholder="Internal notes, pricing calculations, follow-up reminders…"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
            >{q.admin_notes || ''}</textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm transition hover:bg-gray-50"
          >
            Save Notes
          </button>
        </form>
      </div>

      <!-- Quick Info Card -->
      <div class="rounded-xl bg-gray-50 p-6 ring-1 ring-gray-200">
        <h2 class="mb-3 text-sm font-bold text-gray-900">Quick Info</h2>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-gray-500">Quote ID</dt>
            <dd class="font-mono text-xs text-gray-600">{q.id.slice(0, 8)}…</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Created</dt>
            <dd class="text-gray-700">{formatDate(q.created_at)}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Updated</dt>
            <dd class="text-gray-700">{formatDate(q.updated_at)}</dd>
          </div>
          {q.assigned_to && (
            <div class="flex justify-between">
              <dt class="text-gray-500">Assigned</dt>
              <dd class="font-medium text-gray-900">{q.assigned_to}</dd>
            </div>
          )}
        </dl>
      </div>

    </div>
  </div>

</AdminLayout>