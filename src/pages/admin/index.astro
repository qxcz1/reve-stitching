---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAuthClient } from '../../lib/supabase';
import { getQuoteAnalytics } from '../../lib/analytics';

export const prerender = false;

const token = Astro.locals.adminToken;
const supabase = getAuthClient(token);

// Fetch analytics
let analytics;
let error = null;

try {
  analytics = await getQuoteAnalytics(supabase);
  console.log('✅ Analytics loaded successfully');
} catch (err: any) {
  error = err.message;
  console.error('❌ Analytics error:', err);
}

// Fetch other data
const { data: contacts } = await supabase
  .from('contact_submissions')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(50);

const { data: sessions } = await supabase
  .from('chat_sessions')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(50);

const newContacts = contacts?.filter(c => c.status === 'new').length || 0;
const waitingChats = sessions?.filter(s => s.status === 'waiting').length || 0;
const activeChats = sessions?.filter(s => s.status === 'active').length || 0;
---

<AdminLayout title="Dashboard">

{error && (
  <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700">
    <strong>Error:</strong> {error}
  </div>
)}

{analytics && (
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-4">
      📊 Quote Analytics Test
    </h2>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      <!-- Total Quotes -->
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">{analytics.totalQuotes}</p>
        <p class="text-xs opacity-80">Total Quotes</p>
      </div>

      <!-- This Month -->
      <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">{analytics.quotesThisMonth}</p>
        <p class="text-xs opacity-80">This Month</p>
      </div>

      <!-- Active Pipeline -->
      <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">{analytics.activeQuotes}</p>
        <p class="text-xs opacity-80">Active Quotes</p>
      </div>

      <!-- Pipeline Value -->
      <div class="bg-gradient-to-br from-amber-500 to-orange-500 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">
          ${analytics.pipelineValue >= 1000 
            ? `${(analytics.pipelineValue / 1000).toFixed(0)}K` 
            : analytics.pipelineValue}
        </p>
        <p class="text-xs opacity-80">Pipeline Value</p>
      </div>

      <!-- Response Time -->
      <div class="bg-gradient-to-br from-cyan-500 to-teal-500 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">{analytics.avgResponseTime}h</p>
        <p class="text-xs opacity-80">Avg Response</p>
      </div>

      <!-- Conversion Rate -->
      <div class="bg-gradient-to-br from-rose-500 to-pink-500 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">{analytics.conversionRate}%</p>
        <p class="text-xs opacity-80">Conversion</p>
      </div>
    </div>

    <!-- Debug Info -->
    <div class="mt-4 p-4 bg-zinc-100 dark:bg-zinc-800 rounded-xl text-sm font-mono">
      <p><strong>Debug Info:</strong></p>
      <p>• Products: {analytics.products.length} types found</p>
      <p>• Geography: {analytics.geography.length} countries</p>
      <p>• Monthly trend: {analytics.monthlyTrend.length} months</p>
      <p>• Funnel stages: New({analytics.funnel.new.count}) → Won({analytics.funnel.won.count})</p>
    </div>
  </div>
)}

<!-- Original Contact/Chat Stats -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-5">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-600">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">Total Contacts</p>
        <p class="text-2xl font-bold text-zinc-900 dark:text-white">{contacts?.length || 0}</p>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-5">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-50 dark:bg-amber-900/30 text-amber-600">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">New Contacts</p>
        <p class="text-2xl font-bold text-blue-600 dark:text-blue-400">{newContacts}</p>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-5">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">Waiting Chats</p>
        <p class="text-2xl font-bold text-amber-600 dark:text-amber-400">{waitingChats}</p>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-5">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-50 dark:bg-green-900/30 text-green-600">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400">Active Chats</p>
        <p class="text-2xl font-bold text-green-600 dark:text-green-400">{activeChats}</p>
      </div>
    </div>
  </div>
</div>

<!-- Chat Sessions -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <div>
    <h2 class="flex items-center gap-2 text-lg font-semibold text-zinc-900 dark:text-white mb-4">
      <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      Live Chat Sessions
    </h2>
    <div class="space-y-3">
      {(!sessions || sessions.length === 0) && (
        <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-6 text-center text-zinc-400 text-sm">
          No chat sessions yet.
        </div>
      )}
      {sessions?.slice(0, 5).map((session) => (
        <a
          href={`/admin/chat/${session.id}`}
          class="block bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-4 hover:border-primary/50 hover:shadow-md transition-all"
        >
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-zinc-900 dark:text-white">
              {session.visitor_name || 'Anonymous'}
            </span>
            <span class="text-xs text-zinc-400">
              {new Date(session.created_at).toLocaleDateString()}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Contact Submissions -->
  <div>
    <h2 class="flex items-center gap-2 text-lg font-semibold text-zinc-900 dark:text-white mb-4">
      <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      Contact Submissions
    </h2>
    <div class="space-y-3">
      {(!contacts || contacts.length === 0) && (
        <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-6 text-center text-zinc-400 text-sm">
          No submissions yet.
        </div>
      )}
      {contacts?.slice(0, 5).map((contact) => (
        <div class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-zinc-900 dark:text-white">{contact.name}</span>
            <span class="text-xs text-zinc-400">
              {new Date(contact.created_at).toLocaleDateString()}
            </span>
          </div>
          <p class="text-xs text-zinc-500 dark:text-zinc-400">{contact.email}</p>
        </div>
      ))}
    </div>
  </div>
</div>

</AdminLayout>