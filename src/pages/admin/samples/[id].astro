---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';
import { SAMPLE_STATUS_CONFIG } from '../../../lib/types/sample';
import type { SampleRequest } from '../../../lib/types/sample';

export const prerender = false;

const { id } = Astro.params;

const supabase = createClient(
  process.env.SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!,
  { auth: { autoRefreshToken: false, persistSession: false } }
);

const { data, error } = await supabase
  .from('sample_requests')
  .select('*')
  .eq('id', id)
  .single();

if (error || !data) {
  return Astro.redirect('/admin/samples');
}

const sample = data as SampleRequest;
const statusConfig = SAMPLE_STATUS_CONFIG[sample.status];

// Linked quote lookup
let linkedQuote = null;
if (sample.linked_quote_id) {
  const { data: quoteData } = await supabase
    .from('quote_requests')
    .select('reference_number')
    .eq('id', sample.linked_quote_id)
    .single();
  linkedQuote = quoteData;
}

function formatDateTime(iso: string): string {
  return new Date(iso).toLocaleString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

const margin = sample.actual_cost && sample.sample_fee
  ? ((sample.sample_fee - sample.actual_cost) / sample.sample_fee * 100).toFixed(1)
  : null;

// WhatsApp helper — NOW INSIDE THE FRONTMATTER
function sanitizePhone(phone: string | null): string {
  if (!phone) return '';
  let digits = phone.replace(/\D/g, '');
  // If it's a Pakistani local number starting with 0, convert to 92
  if (digits.startsWith('0') && digits.length === 11) {
    digits = '92' + digits.slice(1);
  }
  if (digits.startsWith('00')) {
    digits = digits.slice(2);
  }
  return digits;
}

const whatsappNumber = sample.phone ? sanitizePhone(sample.phone) : '';
const whatsappMessage = `Hi ${sample.contact_person}, regarding sample request ${sample.reference_number}`;
const whatsappUrl = whatsappNumber ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}` : '';

---

<AdminLayout title={`Sample Request - ${sample.reference_number}`}>

  <!-- Header -->
  <div class="mb-6 flex items-center justify-between">
    <div>
      <a href="/admin/samples" class="text-sm text-zinc-500 hover:text-zinc-700 mb-2 inline-flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Samples
      </a>
      <h1 class="text-2xl font-bold text-zinc-900">{sample.reference_number}</h1>
      <p class="text-sm text-zinc-500 mt-1">Submitted {formatDateTime(sample.created_at)}</p>
    </div>
    <span class={`px-4 py-2 rounded-lg text-sm font-semibold ${statusConfig.bg} ${statusConfig.color} border ${statusConfig.border}`}>
      {statusConfig.label}
    </span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Contact Information -->
      <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <h2 class="text-lg font-semibold text-zinc-900 mb-4 flex items-center gap-2">
          <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          Contact Information
        </h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-zinc-500 mb-1">Company</p>
            <p class="text-sm font-medium text-zinc-900">{sample.company_name}</p>
          </div>
          <div>
            <p class="text-xs text-zinc-500 mb-1">Contact Person</p>
            <p class="text-sm font-medium text-zinc-900">{sample.contact_person}</p>
          </div>
          <div>
            <p class="text-xs text-zinc-500 mb-1">Email</p>
            <a href={`mailto:${sample.email}`} class="text-sm text-primary hover:underline">{sample.email}</a>
          </div>
          <div>
            <p class="text-xs text-zinc-500 mb-1">Phone</p>
            {sample.phone ? (
              <p class="text-sm font-medium text-zinc-900">{sample.phone}</p>
            ) : (
              <p class="text-sm text-zinc-400">Not provided</p>
            )}
          </div>
          <div class="col-span-2">
            <p class="text-xs text-zinc-500 mb-1">Country</p>
            <p class="text-sm font-medium text-zinc-900">{sample.country}</p>
          </div>
          <div class="col-span-2">
            <p class="text-xs text-zinc-500 mb-1">Shipping Address</p>
            <p class="text-sm font-medium text-zinc-900 whitespace-pre-line">{sample.shipping_address}</p>
          </div>
        </div>

        <div class="mt-4 pt-4 border-t border-zinc-100 flex gap-2">
          {sample.phone ? (
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
              class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          ) : (
            <button disabled class="px-4 py-2 bg-zinc-300 text-zinc-500 rounded-lg text-sm font-medium cursor-not-allowed flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              No Phone
            </button>
          )}
          <a href={`mailto:${sample.email}?subject=Sample Request ${sample.reference_number}`}
             class="px-4 py-2 bg-zinc-100 text-zinc-700 rounded-lg text-sm font-medium hover:bg-zinc-200 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Send Email
          </a>
        </div>

      <!-- Sample Details -->
      <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <h2 class="text-lg font-semibold text-zinc-900 mb-4 flex items-center gap-2">
          <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          Sample Specifications
        </h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-zinc-500 mb-1">Product Type</p>
            <p class="text-sm font-medium text-zinc-900 capitalize">{sample.product_type}</p>
          </div>
          <div>
            <p class="text-xs text-zinc-500 mb-1">Quantity</p>
            <p class="text-sm font-medium text-zinc-900">{sample.quantity} piece(s)</p>
          </div>
          {sample.fabric_type && (
            <div>
              <p class="text-xs text-zinc-500 mb-1">Fabric Type</p>
              <p class="text-sm font-medium text-zinc-900 capitalize">{sample.fabric_type}</p>
            </div>
          )}
          {sample.gsm && (
            <div>
              <p class="text-xs text-zinc-500 mb-1">GSM</p>
              <p class="text-sm font-medium text-zinc-900">{sample.gsm}</p>
            </div>
          )}
          {sample.color && (
            <div>
              <p class="text-xs text-zinc-500 mb-1">Color</p>
              <p class="text-sm font-medium text-zinc-900">{sample.color}</p>
            </div>
          )}
          {sample.size && (
            <div>
              <p class="text-xs text-zinc-500 mb-1">Size</p>
              <p class="text-sm font-medium text-zinc-900">{sample.size}</p>
            </div>
          )}
        </div>
        {sample.special_requirements && (
          <div class="mt-4 pt-4 border-t border-zinc-100">
            <p class="text-xs text-zinc-500 mb-1">Special Requirements</p>
            <p class="text-sm text-zinc-700 whitespace-pre-line">{sample.special_requirements}</p>
          </div>
        )}
        {linkedQuote && (
          <div class="mt-4 pt-4 border-t border-zinc-100">
            <p class="text-xs text-zinc-500 mb-1">Linked Quote</p>
            <a href={`/admin/quote/${sample.linked_quote_id}`} 
              class="text-sm font-medium text-primary hover:underline">
              {linkedQuote.reference_number}
            </a>
          </div>
        )}
      </div>

      <!-- Shipping Information -->
      {(sample.status === 'shipped' || sample.status === 'delivered') && (
        <div class="bg-white rounded-xl border border-zinc-200 p-6">
          <h2 class="text-lg font-semibold text-zinc-900 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
            Shipping Information
          </h2>
          <div class="grid grid-cols-2 gap-4">
            {sample.shipping_carrier && (
              <div>
                <p class="text-xs text-zinc-500 mb-1">Carrier</p>
                <p class="text-sm font-medium text-zinc-900">{sample.shipping_carrier}</p>
              </div>
            )}
            {sample.tracking_number && (
              <div>
                <p class="text-xs text-zinc-500 mb-1">Tracking Number</p>
                <p class="text-sm font-mono font-medium text-zinc-900">{sample.tracking_number}</p>
              </div>
            )}
            {sample.shipped_at && (
              <div>
                <p class="text-xs text-zinc-500 mb-1">Shipped At</p>
                <p class="text-sm text-zinc-700">{formatDateTime(sample.shipped_at)}</p>
              </div>
            )}
            {sample.delivered_at && (
              <div>
                <p class="text-xs text-zinc-500 mb-1">Delivered At</p>
                <p class="text-sm text-zinc-700">{formatDateTime(sample.delivered_at)}</p>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Admin Notes -->
      {sample.admin_notes && (
        <div class="bg-amber-50 rounded-xl border border-amber-200 p-6">
          <h3 class="text-sm font-semibold text-amber-900 mb-2">Admin Notes</h3>
          <p class="text-sm text-amber-800 whitespace-pre-line">{sample.admin_notes}</p>
        </div>
      )}

      {sample.rejection_reason && (
        <div class="bg-red-50 rounded-xl border border-red-200 p-6">
          <h3 class="text-sm font-semibold text-red-900 mb-2">Rejection Reason</h3>
          <p class="text-sm text-red-800 whitespace-pre-line">{sample.rejection_reason}</p>
        </div>
      )}

    </div>

    <!-- Sidebar -->
    <div class="space-y-6">

      <!-- Cost Tracking -->
      <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <h3 class="text-sm font-semibold text-zinc-900 mb-4">Cost Tracking</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs text-zinc-500">Sample Fee (Buyer)</span>
            <span class="text-sm font-semibold text-zinc-900">
              {sample.is_free_sample ? 'Free' : `$${sample.sample_fee.toFixed(2)}`}
            </span>
          </div>
          {sample.actual_cost && (
            <div class="flex justify-between items-center">
              <span class="text-xs text-zinc-500">Actual Cost</span>
              <span class="text-sm font-medium text-zinc-700">${sample.actual_cost.toFixed(2)}</span>
            </div>
          )}
          {sample.shipping_cost && (
            <div class="flex justify-between items-center">
              <span class="text-xs text-zinc-500">Shipping Cost</span>
              <span class="text-sm font-medium text-zinc-700">${sample.shipping_cost.toFixed(2)}</span>
            </div>
          )}
          {margin && (
            <div class="pt-3 border-t border-zinc-100 flex justify-between items-center">
              <span class="text-xs font-semibold text-zinc-700">Margin</span>
              <span class={`text-sm font-bold ${parseFloat(margin) >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                {margin}%
              </span>
            </div>
          )}
        </div>
      </div>

      <!-- Status Management -->
      <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <h3 class="text-sm font-semibold text-zinc-900 mb-4">Update Status</h3>
        <form id="statusForm" class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-zinc-700 mb-1">Status</label>
            <select name="status" id="statusSelect" 
              class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">
              <option value="new" selected={sample.status === 'new'}>New</option>
              <option value="approved" selected={sample.status === 'approved'}>Approved</option>
              <option value="production" selected={sample.status === 'production'}>In Production</option>
              <option value="shipped" selected={sample.status === 'shipped'}>Shipped</option>
              <option value="delivered" selected={sample.status === 'delivered'}>Delivered</option>
              <option value="converted" selected={sample.status === 'converted'}>Converted</option>
              <option value="rejected" selected={sample.status === 'rejected'}>Rejected</option>
            </select>
          </div>

          <div id="shippingFields" class={sample.status === 'shipped' || sample.status === 'delivered' ? '' : 'hidden'}>
            <div class="mb-3">
              <label class="block text-xs font-medium text-zinc-700 mb-1">Carrier</label>
              <input type="text" name="shipping_carrier" value={sample.shipping_carrier || ''}
                class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">
            </div>
            <div>
              <label class="block text-xs font-medium text-zinc-700 mb-1">Tracking Number</label>
              <input type="text" name="tracking_number" value={sample.tracking_number || ''}
                class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">
            </div>
          </div>

          <div id="rejectionField" class={sample.status === 'rejected' ? '' : 'hidden'}>
            <label class="block text-xs font-medium text-zinc-700 mb-1">Rejection Reason</label>
            <textarea name="rejection_reason" rows="3" 
              class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">{sample.rejection_reason || ''}</textarea>
          </div>

          <div>
            <label class="block text-xs font-medium text-zinc-700 mb-1">Admin Notes</label>
            <textarea name="admin_notes" rows="3" 
              class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">{sample.admin_notes || ''}</textarea>
          </div>

          <button type="submit" id="saveBtn"
            class="w-full px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors disabled:opacity-50">
            Save Changes
          </button>
        </form>

        <div id="statusMessage" class="hidden mt-3 p-3 rounded-lg text-sm"></div>
      </div>

      <!-- Cost Management -->
      <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <h3 class="text-sm font-semibold text-zinc-900 mb-4">Cost Management</h3>
        <form id="costForm" class="space-y-4">
          <div>
            <label class="flex items-center gap-2 mb-3">
              <input 
                type="checkbox" 
                name="is_free_sample" 
                checked={sample.is_free_sample}
                class="rounded border-zinc-300 text-primary focus:ring-primary"
              >
              <span class="text-xs font-medium text-zinc-700">Free Sample</span>
            </label>
          </div>
          <div>
            <label class="block text-xs font-medium text-zinc-700 mb-1">Sample Fee ($)</label>
            <input type="number" name="sample_fee" value={sample.sample_fee} step="0.01" min="0"
              class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">
          </div>
          <div>
            <label class="block text-xs font-medium text-zinc-700 mb-1">Actual Cost ($)</label>
            <input type="number" name="actual_cost" value={sample.actual_cost || ''} step="0.01" min="0"
              class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">
          </div>
          <div>
            <label class="block text-xs font-medium text-zinc-700 mb-1">Shipping Cost ($)</label>
            <input type="number" name="shipping_cost" value={sample.shipping_cost || ''} step="0.01" min="0"
              class="w-full px-3 py-2 rounded-lg border border-zinc-300 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20">
          </div>
          <button type="submit" id="costBtn"
            class="w-full px-4 py-2 bg-zinc-700 text-white rounded-lg text-sm font-medium hover:bg-zinc-800 transition-colors disabled:opacity-50">
            Update Costs
          </button>
        </form>

        <div id="costMessage" class="hidden mt-3 p-3 rounded-lg text-sm"></div>
      </div>

    </div>

  </div>

  <script define:vars={{ sampleId: sample.id }}>
    const statusForm = document.getElementById('statusForm');
    const statusSelect = document.getElementById('statusSelect');
    const shippingFields = document.getElementById('shippingFields');
    const rejectionField = document.getElementById('rejectionField');
    const statusMessage = document.getElementById('statusMessage');
    const saveBtn = document.getElementById('saveBtn');

    const costForm = document.getElementById('costForm');
    const costMessage = document.getElementById('costMessage');
    const costBtn = document.getElementById('costBtn');

    // Show/hide conditional fields
    statusSelect?.addEventListener('change', () => {
      const status = statusSelect.value;
      if (status === 'shipped' || status === 'delivered') {
        shippingFields?.classList.remove('hidden');
      } else {
        shippingFields?.classList.add('hidden');
      }
      if (status === 'rejected') {
        rejectionField?.classList.remove('hidden');
      } else {
        rejectionField?.classList.add('hidden');
      }
    });

    // Status update
    statusForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      const formData = new FormData(statusForm);
      const data = Object.fromEntries(formData.entries());

      // Add timestamp for shipped/delivered
      if (data.status === 'shipped' && !data.shipped_at) {
        data.shipped_at = new Date().toISOString();
      }
      if (data.status === 'delivered' && !data.delivered_at) {
        data.delivered_at = new Date().toISOString();
      }

      try {
        const res = await fetch(`/api/admin/samples/${sampleId}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok) {
          statusMessage.className = 'mt-3 p-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-200';
          statusMessage.textContent = 'Status updated successfully!';
          statusMessage.classList.remove('hidden');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          throw new Error(result.error || 'Update failed');
        }
      } catch (err) {
        statusMessage.className = 'mt-3 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
        statusMessage.textContent = err.message;
        statusMessage.classList.remove('hidden');
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';
      }
    });

    // Cost update
    costForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      costBtn.disabled = true;
      costBtn.textContent = 'Updating...';

      const formData = new FormData(costForm);
      const data = {
        is_free_sample: formData.get('is_free_sample') === 'on',
        sample_fee: parseFloat(formData.get('sample_fee')) || 0,
        actual_cost: parseFloat(formData.get('actual_cost')) || null,
        shipping_cost: parseFloat(formData.get('shipping_cost')) || null,
      };

      try {
        const res = await fetch(`/api/admin/samples/${sampleId}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok) {
          costMessage.className = 'mt-3 p-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-200';
          costMessage.textContent = 'Costs updated successfully!';
          costMessage.classList.remove('hidden');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          throw new Error(result.error || 'Update failed');
        }
      } catch (err) {
        costMessage.className = 'mt-3 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
        costMessage.textContent = err.message;
        costMessage.classList.remove('hidden');
        costBtn.disabled = false;
        costBtn.textContent = 'Update Costs';
      }
    });
  </script>

</AdminLayout>