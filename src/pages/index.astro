---
import Layout from '../layouts/Layout.astro';
import PriceCalculator from '../components/PriceCalculator.astro';

const title = 'Reve Stitching — Premium Garment Manufacturing';
const description =
  '100% export-oriented knitted garment manufacturer based in Faisalabad, Pakistan. Serving UK & EU retailers with premium quality, fast turnaround, and ethical production.';

const steps = [
  {
    num: '01',
    title: 'Design & Development',
    body: 'Your vision meets our expertise. We collaborate on design concepts, fabric selection, and technical specifications to create the perfect blueprint for your garments.',
    tags: ['CAD Patterns', 'Tech Packs', 'Fabric Sourcing'],
    image: 'https://images.unsplash.com/photo-1581291518857-4e27b48ff24e?auto=format&fit=crop&w=800&h=500&q=80',
    alt: 'Design workspace with technical drawings and fabric swatches',
  },
  {
    num: '02',
    title: 'Sampling',
    body: 'Before mass production begins we create detailed samples for your approval — fit samples, pre-production samples, and size sets — perfected to your exact specifications.',
    tags: ['Fit Samples', 'PP Samples', 'Size Sets'],
    image: 'https://images.unsplash.com/photo-1544441893-675973e31985?auto=format&fit=crop&w=800&h=500&q=80',
    alt: 'Colorful fabric samples and textile swatches for evaluation',
  },
  {
    num: '03',
    title: 'Production',
    body: 'State-of-the-art knitting, cutting, stitching, and finishing lines operate with surgical precision. Real-time quality monitoring ensures consistency across every single piece.',
    tags: ['Knitting', 'Cutting', 'Stitching', 'Finishing'],
    image: 'https://images.unsplash.com/photo-1565688534245-05d6b5be184a?auto=format&fit=crop&w=800&h=500&q=80',
    alt: 'Modern garment production floor with industrial sewing machines',
  },
  {
    num: '04',
    title: 'Quality Control',
    body: 'Every garment passes through rigorous AQL 2.5 inspection. Fabric testing, measurement checks, and final audits guarantee export-ready quality — no exceptions.',
    tags: ['AQL 2.5', 'Lab Testing', 'Final Audit'],
    image: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=800&h=500&q=80',
    alt: 'Quality inspector checking garment specifications',
  },
  {
    num: '05',
    title: 'Shipment',
    body: 'Expertly packed and dispatched. We handle logistics coordination, documentation, and customs compliance for seamless delivery to your warehouse.',
    tags: ['Packing', 'Logistics', 'Documentation'],
    image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=800&h=500&q=80',
    alt: 'Warehouse with packed garment boxes ready for shipment',
  },
];

const products = [
  {
    name: 'T-Shirts',
    image: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Premium cotton t-shirt',
  },
  {
    name: 'Hoodies & Sweatshirts',
    image: 'https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Premium hoodie with custom branding',
  },
  {
    name: 'Polo Shirts',
    image: 'https://images.unsplash.com/photo-1589310243389-96a5483213a8?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Corporate polo shirt',
  },
  {
    name: 'Joggers & Trousers',
    image: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Athletic joggers with custom design',
  },
  {
    name: "Ladies' Wear",
    image: 'https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Ladies fashion garment',
  },
  {
    name: "Kids' Wear",
    image: 'https://images.unsplash.com/photo-1519238263530-99bdd11df2ea?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Colorful kids wear collection',
  },
];

const capabilities = [
  {
    title: 'Premium Quality',
    body: 'International quality standards with AQL 2.5 inspection and lab-tested fabrics. Every garment is built to exceed expectations.',
  },
  {
    title: 'Fast Turnaround',
    body: '25–50 day lead times from sampling to shipment. Speed without compromise on quality.',
  },
  {
    title: 'Custom Solutions',
    body: 'Full customisation — fabrics, washes, prints, embroidery, labels, and packaging — all tailored to your brand.',
  },
  {
    title: 'Ethical Production',
    body: 'Fair wages, safe working conditions, and sustainable practices across every facility we operate.',
  },
  {
    title: 'Global Reach',
    body: 'Exporting to the UK and Europe. Trusted by leading high-street and e-commerce retailers.',
  },
  {
    title: 'Tech-Driven',
    body: 'Modern machinery, digital pattern-making, and real-time production tracking dashboards.',
  },
];

const clients = [
  'Boohoo',
  'CLOSURE',
  'Yours',
  'Pull & Bear',
  'Daisy Street',
  'MARSHALL ARTIST',
  'Threadbare',
  'HELME',
  'FOREVER CLUB',
];
---

<Layout title={title} description={description}>

  <!-- ════════════════════════════════════════════════════════
       HERO — Light editorial, massive typography
       ════════════════════════════════════════════════════════ -->
  <section
    id="hero"
    class="relative flex min-h-[calc(100dvh-5rem)] flex-col bg-zinc-50 dark:bg-zinc-950"
    data-snap
    data-hero
    aria-label="Hero"
  >
    <!-- Subtle grid texture (light) -->
    <div
      class="pointer-events-none absolute inset-0 dark:hidden"
      aria-hidden="true"
      style="background-image:linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>
    <!-- Subtle grid texture (dark) -->
    <div
      class="pointer-events-none absolute inset-0 hidden dark:block"
      aria-hidden="true"
      style="background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>

    <!-- Decorative gradient blobs -->
    <div
      class="pointer-events-none absolute right-[8%] top-[12%] h-80 w-80 rounded-full bg-green-500/[0.08] blur-3xl dark:bg-green-500/[0.05]"
      data-hero-deco
      data-float
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-[18%] left-[4%] h-64 w-64 rounded-full bg-emerald-400/[0.06] blur-3xl dark:bg-emerald-400/[0.04]"
      data-hero-deco
      data-float
      data-float-amplitude="12"
      data-float-duration="6"
      aria-hidden="true"
    ></div>

    <!-- Content -->
    <div class="relative z-10 mt-auto pb-20 lg:my-auto lg:pb-0" data-hero-content>
      <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

        <!-- Eyebrow -->
        <div class="mb-6 flex items-center gap-3 lg:mb-8" data-animate="fade-up">
          <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">
            Export Garment Manufacturer · Faisalabad
          </span>
        </div>

        <!-- Heading -->
        <h1>
          <span
            class="block font-serif font-bold leading-[0.88] tracking-tight text-zinc-900 dark:text-white"
            style="font-size:clamp(2.75rem,7vw,8.5rem)"
            data-animate="fade-up"
          >
            Premium Garment
          </span>
          <span
            class="block font-serif font-bold leading-[0.88] tracking-tight text-zinc-900 dark:text-white"
            style="font-size:clamp(2.75rem,7vw,8.5rem)"
            data-animate="fade-up"
            data-delay="0.08"
          >
            Manufacturing for
          </span>
          <span
            class="block font-serif font-bold leading-[0.88] tracking-tight"
            style="font-size:clamp(2.75rem,7vw,8.5rem)"
            data-animate="fade-up"
            data-delay="0.16"
          >
            <span class="bg-gradient-to-r from-green-600 to-emerald-500 bg-clip-text text-transparent dark:from-green-400 dark:to-emerald-300">
              Global Brands
            </span>
          </span>
        </h1>

        <!-- Sub-copy + CTA -->
        <div class="mt-8 flex flex-col gap-8 lg:mt-12 lg:flex-row lg:items-end lg:justify-between">
          <p
            class="max-w-lg text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg"
            data-animate="fade-up"
            data-delay="0.24"
          >
            100% export-oriented knitted garment manufacturer.
            From Faisalabad to the UK's leading retailers —
            with precision, speed, and integrity.
          </p>

          <div class="flex items-center gap-4" data-animate="fade-up" data-delay="0.3">
            <a
              href="/quote/"
              class="inline-flex items-center gap-2 rounded-full bg-green-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 hover:shadow-green-700/25 dark:bg-green-500 dark:text-zinc-950 dark:shadow-green-500/20 dark:hover:bg-green-400"
              data-magnetic
            >
              Get a Quote
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="/products/"
              class="px-5 py-4 text-sm font-medium uppercase tracking-wider text-zinc-400 transition-colors hover:text-zinc-900 dark:text-white/50 dark:hover:text-white"
            >
              View Our Work
            </a>
          </div>
        </div>

        <!-- Trust line -->
        <div class="mt-10 flex items-center gap-3 lg:mt-14" data-animate="fade-up" data-delay="0.36">
          <span class="text-[11px] font-medium uppercase tracking-wider text-zinc-400 dark:text-zinc-500">Trusted by</span>
          <span class="h-px w-4 bg-zinc-300 dark:bg-zinc-700" aria-hidden="true"></span>
          <span class="text-[11px] font-medium text-zinc-400 dark:text-zinc-500">
            Boohoo · Pull&nbsp;&amp;&nbsp;Bear · Yours Clothing &amp; more
          </span>
        </div>
      </div>
    </div>

    <!-- Floating stat badges (desktop only) -->
    <div class="pointer-events-none absolute right-[7%] top-[24%] z-10 hidden xl:block" data-float>
      <div class="rounded-2xl border border-zinc-200 bg-white/90 px-5 py-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/80">
        <span class="block text-2xl font-bold text-zinc-900 dark:text-white">300K+</span>
        <span class="text-[11px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Monthly Pieces</span>
      </div>
    </div>
    <div
      class="pointer-events-none absolute right-[14%] top-[50%] z-10 hidden xl:block"
      data-float
      data-float-amplitude="10"
      data-float-duration="5.5"
    >
      <div class="rounded-2xl border border-zinc-200 bg-white/90 px-5 py-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/80">
        <span class="block text-2xl font-bold text-green-600 dark:text-green-400">Since 2019</span>
        <span class="text-[11px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Established</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute inset-x-0 bottom-6 z-10 flex justify-center" aria-hidden="true" data-animate="fade-up" data-delay="0.5">
      <div class="flex flex-col items-center gap-2">
        <span class="text-[10px] font-medium uppercase tracking-[0.35em] text-zinc-400 dark:text-zinc-500">Scroll</span>
        <div class="flex h-9 w-5 items-start justify-center rounded-full border border-zinc-300 p-1 dark:border-zinc-700">
          <div class="h-1.5 w-1.5 animate-bounce rounded-full bg-green-500"></div>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       PROCESS — Sticky left + snapping right panels
       ════════════════════════════════════════════════════════ -->
  <section
    id="process"
    class="relative bg-white dark:bg-zinc-950"
    aria-label="Our Production Process"
  >
    <!-- Section header -->
    <div class="mx-auto max-w-[90rem] px-6 pb-12 pt-24 sm:px-8 lg:px-12 lg:pb-0 lg:pt-32 xl:px-16">
      <div class="max-w-2xl" data-animate="fade-up">
        <span class="mb-4 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">
          How We Work
        </span>
        <h2 class="font-serif text-4xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
          From Concept<br class="hidden sm:block" /> to Container
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-zinc-500 dark:text-zinc-400">
          A vertically-integrated production workflow built for reliability,
          speed, and uncompromising quality at every stage.
        </p>
      </div>
    </div>

    <!-- Sticky left + scrolling right grid -->
    <div class="mx-auto max-w-[90rem] lg:grid lg:grid-cols-2 lg:px-0">

      <!-- LEFT — sticky overview panel (desktop only) -->
      <div class="hidden lg:block">
        <div class="sticky top-20 flex h-[calc(100dvh-5rem)] flex-col justify-center px-12 xl:px-16">
          <div class="relative">
            <span
              class="pointer-events-none absolute -left-4 -top-20 select-none font-serif text-[12rem] font-bold leading-none text-zinc-100 dark:text-white/[0.03]"
              aria-hidden="true"
            >05</span>

            <div class="absolute -left-6 bottom-0 top-0 w-px bg-gradient-to-b from-green-500/50 via-green-500/20 to-transparent" aria-hidden="true"></div>

            <p class="text-sm font-medium uppercase tracking-[0.2em] text-green-600 dark:text-green-400">
              Production Workflow
            </p>
            <p class="mt-4 text-3xl font-bold text-zinc-900 dark:text-white xl:text-4xl">
              5 Precision<br />Controlled Stages
            </p>
            <p class="mt-4 max-w-md text-base leading-relaxed text-zinc-500 dark:text-zinc-500">
              Every garment passes through a streamlined pipeline designed to
              deliver export-grade quality on time, every time.
            </p>

            <ul class="mt-10 space-y-3">
              {steps.map((s) => (
                <li class="flex items-center gap-3">
                  <span class="flex h-7 w-7 items-center justify-center rounded-full border border-zinc-200 text-[11px] font-bold text-zinc-400 dark:border-zinc-700 dark:text-zinc-500">
                    {s.num}
                  </span>
                  <span class="text-sm text-zinc-500 dark:text-zinc-500">{s.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- RIGHT — scrolling step panels (each snaps into view) -->
      <div>
        {steps.map((step, i) => (
          <div
            class={`flex min-h-[65vh] flex-col justify-center px-6 py-16 sm:py-20 lg:min-h-screen lg:px-12 xl:px-20 ${i < steps.length - 1 ? 'border-b border-zinc-100 dark:border-zinc-800/60' : ''}`}
            data-snap
            data-animate="fade-up"
          >
            <div class="mb-6 flex items-center gap-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-500/10 font-serif text-xl font-bold text-green-600 dark:text-green-400">
                {step.num}
              </span>
              <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-800" aria-hidden="true"></div>
            </div>

            <h3 class="font-serif text-3xl font-bold text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
              {step.title}
            </h3>

            <p class="mt-4 max-w-lg text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg">
              {step.body}
            </p>

            <div class="mt-6 flex flex-wrap gap-2">
              {step.tags.map((tag: string) => (
                <span class="rounded-full border border-zinc-200 px-4 py-1.5 text-xs font-medium text-zinc-500 dark:border-zinc-700 dark:text-zinc-400">
                  {tag}
                </span>
              ))}
            </div>

            <div class="mt-8 overflow-hidden rounded-2xl">
              <img
                src={step.image}
                alt={step.alt}
                class="aspect-[16/10] w-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════
       CAPABILITIES — Asymmetric Bento Grid
       ════════════════════════════════════════════════════════ -->
  <section
    id="capabilities"
    class="relative bg-zinc-50 py-24 dark:bg-zinc-900 lg:py-32 xl:py-40"
    data-snap
    aria-label="Our Capabilities"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

      <div class="mb-16 flex flex-col items-start gap-6 lg:mb-24 lg:flex-row lg:items-end lg:justify-between">
        <div data-animate="fade-up">
          <span class="mb-4 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">
            Capabilities
          </span>
          <h2 class="font-serif text-4xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            Why Brands<br />Choose Us
          </h2>
        </div>
        <p class="max-w-md text-base leading-relaxed text-zinc-500 dark:text-zinc-400 lg:text-right lg:text-lg" data-animate="fade-up" data-delay="0.1">
          Six pillars that define our manufacturing philosophy
          — and why leading UK &amp; EU retailers trust Reve Stitching.
        </p>
      </div>

      <div
        class="grid auto-rows-[minmax(220px,auto)] grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 lg:auto-rows-[minmax(260px,auto)] lg:grid-cols-3 lg:gap-6"
        data-bento
      >
        <!-- Card 1 — Premium Quality (tall, spans 2 rows) -->
        <div
          class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-green-700 to-green-900 p-8 text-white lg:row-span-2 lg:p-10"
          data-bento-item
          data-tilt
        >
          <div class="relative z-10 flex h-full flex-col">
            <span class="mb-auto inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            </span>
            <div class="mt-8">
              <h3 class="text-2xl font-bold lg:text-3xl">{capabilities[0].title}</h3>
              <p class="mt-3 max-w-sm text-sm leading-relaxed text-white/70 lg:text-base">{capabilities[0].body}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute -bottom-20 -right-20 h-60 w-60 rounded-full bg-green-500/20 blur-3xl transition-transform duration-700 group-hover:scale-125" aria-hidden="true"></div>
        </div>

        <!-- Card 2 — Fast Turnaround (wide, spans 2 cols) -->
        <div
          class="group relative overflow-hidden rounded-3xl bg-white p-8 dark:bg-zinc-800 lg:col-span-2 lg:p-10"
          data-bento-item
          data-tilt
        >
          <div class="relative z-10 flex h-full flex-col justify-between sm:flex-row sm:items-end sm:gap-10">
            <div>
              <span class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-100 dark:bg-zinc-700">
                <svg class="h-7 w-7 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </span>
              <h3 class="text-2xl font-bold text-zinc-900 dark:text-white lg:text-3xl">{capabilities[1].title}</h3>
              <p class="mt-3 max-w-md text-sm leading-relaxed text-zinc-500 dark:text-zinc-400 lg:text-base">{capabilities[1].body}</p>
            </div>
            <span class="mt-4 font-serif text-6xl font-bold text-zinc-100 dark:text-zinc-700 sm:mt-0 sm:text-8xl">
              25–50
              <span class="block text-sm font-sans font-normal uppercase tracking-wider text-zinc-400 dark:text-zinc-500">days</span>
            </span>
          </div>
        </div>

        <!-- Card 3 — Custom Solutions -->
        <div class="group overflow-hidden rounded-3xl bg-white p-8 dark:bg-zinc-800 lg:p-10" data-bento-item data-tilt>
          <span class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-100 dark:bg-zinc-700">
            <svg class="h-7 w-7 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </span>
          <h3 class="text-xl font-bold text-zinc-900 dark:text-white lg:text-2xl">{capabilities[2].title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[2].body}</p>
        </div>

        <!-- Card 4 — Ethical Production -->
        <div class="group overflow-hidden rounded-3xl bg-white p-8 dark:bg-zinc-800 lg:p-10" data-bento-item data-tilt>
          <span class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-100 dark:bg-zinc-700">
