---
/**
 * Reve Stitching — Homepage
 * Clean, honest, scroll-driven cinematic experience.
 * Process section uses pinned steps with scroll snap.
 * Light mode default. Only Hero + CTA are dark.
 */
import Layout from '../layouts/Layout.astro';
import PriceCalculator from '../components/PriceCalculator.astro';

const title = 'Reve Stitching — Premium Garment Manufacturing';
const description =
  '100% export-oriented knitted garment manufacturer based in Faisalabad, Pakistan. 300K+ monthly capacity, 25-50 day lead times, serving UK retailers.';

const steps = [
  {
    num: '01',
    title: 'Design & Development',
    body: 'We collaborate on design concepts, fabric selection, and technical specifications to create the perfect blueprint for your garments.',
    tags: ['CAD Patterns', 'Tech Packs', 'Fabric Sourcing'],
  },
  {
    num: '02',
    title: 'Sampling',
    body: 'Detailed samples for your approval — fit samples, pre-production samples, and size sets — perfected to your exact specifications before production begins.',
    tags: ['Fit Samples', 'PP Samples', 'Size Sets'],
  },
  {
    num: '03',
    title: 'Production',
    body: 'State-of-the-art knitting, cutting, stitching, and finishing lines with real-time quality monitoring ensuring consistency across every piece.',
    tags: ['Knitting', 'Cutting', 'Stitching', 'Finishing'],
  },
  {
    num: '04',
    title: 'Quality Control',
    body: 'Every garment passes through rigorous AQL 2.5 inspection. Fabric testing, measurement checks, and final audits guarantee export-ready quality.',
    tags: ['AQL 2.5', 'Lab Testing', 'Final Audit'],
  },
  {
    num: '05',
    title: 'Shipment',
    body: 'Expertly packed and dispatched. We handle logistics coordination, documentation, and customs compliance for seamless delivery to your door.',
    tags: ['Packing', 'Logistics', 'Documentation'],
  },
];

const products = [
  { name: 'T-Shirts' },
  { name: 'Hoodies & Sweatshirts' },
  { name: 'Polo Shirts' },
  { name: 'Joggers & Trousers' },
  { name: "Ladies' Wear" },
  { name: "Kids' Wear" },
];

const capabilities = [
  {
    title: 'Premium Quality',
    body: 'International quality standards with AQL 2.5 inspection and lab-tested fabrics across every production run.',
  },
  {
    title: 'Fast Turnaround',
    body: '25–50 day lead times from sampling to shipment. Speed without compromise on quality.',
  },
  {
    title: 'Custom Solutions',
    body: 'Full customisation — fabrics, washes, prints, embroidery, labels, and packaging tailored to your brand.',
  },
  {
    title: 'Ethical Production',
    body: 'SEDEX certified. Fair wages, safe working conditions, and sustainable practices across our facility.',
  },
  {
    title: 'UK Market Focused',
    body: 'Built for UK retailers. We understand UK sizing, compliance requirements, and delivery expectations.',
  },
  {
    title: 'Tech-Driven',
    body: 'Modern machinery, digital pattern-making, and ERP-powered production tracking for full transparency.',
  },
];

const clients = ['Boohoo', 'Pull & Bear', 'Yours Clothing', 'Simply Be', 'JD Williams', 'Jacamo'];
---

<Layout title={title} description={description}>

  <!-- ═══════════════════════════════════════
       1. HERO — Dark, cinematic, clean
       ═══════════════════════════════════════ -->
  <section
    id="hero"
    class="relative flex min-h-[calc(100dvh-5rem)] flex-col bg-zinc-950"
    data-snap
    data-hero
    data-cursor-dark
    aria-label="Hero"
  >
    <div class="absolute inset-0" data-hero-deco>
      <div class="absolute inset-0 bg-zinc-900"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/80 to-zinc-950/30"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-zinc-950/50"></div>
    </div>

    <div
      class="pointer-events-none absolute inset-0 opacity-[0.03]"
      aria-hidden="true"
      style="background-image:linear-gradient(rgba(255,255,255,.12) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.12) 1px,transparent 1px);background-size:72px 72px"
    ></div>

    <div class="relative z-10 mt-auto pb-16 sm:pb-20 lg:pb-28" data-hero-content>
      <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

        <div class="mb-7 flex items-center gap-3" data-animate="fade-up">
          <span class="block h-px w-8 bg-green-400" aria-hidden="true"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.3em] text-green-400">
            Export Garment Manufacturer · Faisalabad, Pakistan
          </span>
        </div>

        <h1>
          <span
            class="block font-serif font-bold leading-[0.9] tracking-tight text-white"
            style="font-size:clamp(2.5rem,7vw,8rem)"
            data-animate="fade-up"
          >Premium Garment</span>
          <span
            class="block font-serif font-bold leading-[0.9] tracking-tight text-white"
            style="font-size:clamp(2.5rem,7vw,8rem)"
            data-animate="fade-up"
            data-delay="0.08"
          >Manufacturing for</span>
          <span
            class="block font-serif font-bold leading-[0.9] tracking-tight"
            style="font-size:clamp(2.5rem,7vw,8rem)"
            data-animate="fade-up"
            data-delay="0.16"
          ><span class="bg-gradient-to-r from-green-400 to-emerald-300 bg-clip-text text-transparent">Global Brands</span></span>
        </h1>

        <div class="mt-10 flex flex-col gap-8 lg:mt-14 lg:flex-row lg:items-end lg:justify-between">
          <p
            class="max-w-lg text-base leading-relaxed text-zinc-400 sm:text-lg"
            data-animate="fade-up"
            data-delay="0.24"
          >
            100% export-oriented knitted garment manufacturer with 300,000+ monthly
            capacity. From concept to container — delivering quality UK retailers trust.
          </p>

          <div class="flex items-center gap-4" data-animate="fade-up" data-delay="0.32">
            <a
              href="/quote/"
              class="inline-flex items-center gap-2 rounded-full bg-green-500 px-8 py-4 text-sm font-bold uppercase tracking-wider text-zinc-950 shadow-xl shadow-green-500/20 transition-all duration-300 hover:bg-green-400"
              data-magnetic
            >
              Get a Quote
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/products/" class="px-5 py-4 text-sm font-medium uppercase tracking-wider text-white/60 transition-colors hover:text-white">
              View Products
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute inset-x-0 bottom-6 z-10 flex justify-center" aria-hidden="true" data-animate="fade-up" data-delay="0.5">
      <div class="flex flex-col items-center gap-2">
        <span class="text-[10px] font-medium uppercase tracking-[0.35em] text-zinc-500">Scroll</span>
        <div class="flex h-9 w-5 items-start justify-center rounded-full border border-zinc-600 p-1">
          <div class="h-1.5 w-1.5 animate-bounce rounded-full bg-green-400"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       2. STATS — Light, animated counters
       ═══════════════════════════════════════ -->
  <section
    id="stats"
    class="bg-white py-20 dark:bg-zinc-950 lg:py-24"
    data-snap
    aria-label="Key Statistics"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4 lg:gap-12" data-stagger="0.1">

        <div class="text-center" data-animate="fade-up">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="300000">0</span><span class="text-green-600 dark:text-green-400">+</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Monthly Capacity</p>
        </div>

        <div class="text-center" data-animate="fade-up">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="25">0</span>–<span data-counter="50">0</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Days Lead Time</p>
        </div>

        <div class="text-center" data-animate="fade-up">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="100">0</span><span class="text-green-600 dark:text-green-400">%</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Export Oriented</p>
        </div>

        <div class="text-center" data-animate="fade-up">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="10">0</span><span class="text-green-600 dark:text-green-400">+</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Years Experience</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       3. PROCESS — Pinned scroll with snap
       Desktop: section pins, scroll transitions between steps
       Mobile: steps stack vertically
       ═══════════════════════════════════════ -->
  <section
    id="process"
    class="relative bg-zinc-50 dark:bg-zinc-900 lg:overflow-hidden"
    data-pinned-steps
    aria-label="Our Production Process"
  >
    <div class="lg:flex lg:h-screen" data-steps-viewport>

      <!-- LEFT: Section info + step indicators (desktop) -->
      <div class="px-6 py-16 sm:px-8 lg:flex lg:w-[42%] lg:flex-col lg:justify-center lg:px-16 lg:py-0 xl:px-20">
        <div>
          <span class="mb-4 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400" data-animate="fade-up">
            How We Work
          </span>
          <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate="fade-up">
            From Concept<br />to Container
          </h2>
          <p class="mt-5 max-w-md text-base leading-relaxed text-zinc-600 dark:text-zinc-400" data-animate="fade-up">
            A vertically-integrated production workflow built for
            reliability, speed, and quality at every stage.
          </p>

          <!-- Step indicators (desktop only) -->
          <div class="mt-10 hidden lg:flex lg:flex-col lg:gap-1">
            {steps.map((s, i) => (
              <div data-step-indicator={i} class="flex items-center gap-3 rounded-lg px-3 py-2.5">
                <span class="step-dot flex h-8 w-8 items-center justify-center rounded-full border text-xs font-bold">
                  {s.num}
                </span>
                <span class="step-label text-sm font-medium text-zinc-600 dark:text-zinc-400">
                  {s.title}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT: Step panels -->
      <div class="relative lg:flex-1" data-steps-container>
        {steps.map((step, i) => (
          <div
            data-step-panel
            class={`border-b border-zinc-200 px-6 py-14 dark:border-zinc-800 sm:px-8 lg:flex lg:items-center lg:border-0 lg:px-16 lg:py-0 xl:px-20 ${i > 0 ? '' : ''}`}
          >
            <div class="w-full max-w-xl">
              <div class="mb-5 flex items-center gap-4">
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 font-serif text-xl font-bold text-green-700 dark:bg-green-500/10 dark:text-green-400">
                  {step.num}
                </span>
                <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-700" aria-hidden="true"></div>
              </div>

              <h3 class="font-serif text-2xl font-bold text-zinc-900 dark:text-white sm:text-3xl lg:text-4xl">
                {step.title}
              </h3>

              <p class="mt-4 text-base leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-lg">
                {step.body}
              </p>

              <div class="mt-6 flex flex-wrap gap-2">
                {step.tags.map((tag: string) => (
                  <span class="rounded-full border border-zinc-300 bg-white px-4 py-1.5 text-xs font-medium text-zinc-600 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════
       4. CAPABILITIES — Bento Grid
       ═══════════════════════════════════════ -->
  <section
    id="capabilities"
    class="bg-white py-24 dark:bg-zinc-950 lg:py-32"
    data-snap
    aria-label="Our Capabilities"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

      <div class="mb-14 flex flex-col items-start gap-5 lg:mb-20 lg:flex-row lg:items-end lg:justify-between">
        <div data-animate="fade-up">
          <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Capabilities</span>
          <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
            Why Brands<br />Choose Us
          </h2>
        </div>
        <p class="max-w-md text-base leading-relaxed text-zinc-500 dark:text-zinc-400 lg:text-right" data-animate="fade-up">
          Six pillars that define how we manufacture — and why
          UK retailers trust Reve Stitching with their production.
        </p>
      </div>

      <div
        class="grid auto-rows-[minmax(200px,auto)] grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 lg:auto-rows-[minmax(240px,auto)] lg:grid-cols-3 lg:gap-6"
        data-bento
      >
        <!-- Card 1: Premium Quality (tall) -->
        <div
          class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-green-700 to-green-900 p-8 text-white lg:row-span-2 lg:p-10"
          data-bento-item
        >
          <div class="relative z-10 flex h-full flex-col">
            <span class="mb-auto flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-xl">✦</span>
            <div class="mt-8">
              <h3 class="text-xl font-bold lg:text-2xl">{capabilities[0].title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-white/70">{capabilities[0].body}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute -bottom-16 -right-16 h-48 w-48 rounded-full bg-green-500/20 blur-3xl" aria-hidden="true"></div>
        </div>

        <!-- Card 2: Fast Turnaround (wide) -->
        <div class="group overflow-hidden rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:col-span-2 lg:p-10" data-bento-item>
          <div class="flex h-full flex-col justify-between sm:flex-row sm:items-end sm:gap-8">
            <div>
              <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 text-xl dark:bg-zinc-800">⚡</span>
              <h3 class="text-xl font-bold text-zinc-900 dark:text-white lg:text-2xl">{capabilities[1].title}</h3>
              <p class="mt-2 max-w-md text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[1].body}</p>
            </div>
            <span class="mt-4 font-serif text-5xl font-bold text-zinc-200 dark:text-zinc-800 sm:mt-0 sm:text-7xl">
              25–50<span class="block text-xs font-sans font-normal uppercase tracking-wider text-zinc-400">days</span>
            </span>
          </div>
        </div>

        <!-- Card 3: Custom Solutions -->
        <div class="rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:p-10" data-bento-item>
          <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 text-xl dark:bg-zinc-800">◈</span>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white lg:text-xl">{capabilities[2].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[2].body}</p>
        </div>

        <!-- Card 4: Ethical Production -->
        <div class="rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:p-10" data-bento-item>
          <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 text-xl dark:bg-zinc-800">♻</span>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white lg:text-xl">{capabilities[3].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[3].body}</p>
        </div>

        <!-- Card 5: UK Market Focused (wide) -->
        <div class="group relative overflow-hidden rounded-2xl bg-zinc-900 p-8 text-white dark:bg-zinc-800 lg:col-span-2 lg:p-10" data-bento-item>
          <div class="relative z-10 flex h-full flex-col justify-between sm:flex-row sm:items-end sm:gap-8">
            <div>
              <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-xl">◎</span>
              <h3 class="text-xl font-bold lg:text-2xl">{capabilities[4].title}</h3>
              <p class="mt-2 max-w-md text-sm leading-relaxed text-white/60">{capabilities[4].body}</p>
            </div>
            <div class="mt-4 flex gap-2 sm:mt-0" aria-hidden="true">
              <span class="flex items-center gap-2 rounded-full border border-white/20 px-3 py-1 text-xs text-white/60">
                <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span> UK
              </span>
              <span class="flex items-center gap-2 rounded-full border border-white/20 px-3 py-1 text-xs text-white/60">
                <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span> EU
              </span>
            </div>
          </div>
        </div>

        <!-- Card 6: Tech-Driven -->
        <div class="rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:p-10" data-bento-item>
          <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 text-xl dark:bg-zinc-800">⬡</span>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white lg:text-xl">{capabilities[5].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[5].body}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       5. PRODUCTS — Clean grid
       ═══════════════════════════════════════ -->
  <section
    id="products"
    class="bg-zinc-50 py-24 dark:bg-zinc-900 lg:py-32"
    data-snap
    aria-label="Product Categories"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

      <div class="mb-14 flex flex-col gap-5 lg:mb-20 lg:flex-row lg:items-end lg:justify-between">
        <div data-animate="fade-up">
          <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Product Range</span>
          <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
            What We Manufacture
          </h2>
        </div>
        <a href="/products/" class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-green-600 transition-colors hover:text-green-700 dark:text-green-400" data-magnetic>
          View All Products
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger="0.08">
        {products.map((product, i) => (
          <a
            href="/products/"
            class="group relative block overflow-hidden rounded-2xl bg-zinc-200 dark:bg-zinc-800"
            data-animate="fade-up"
          >
            <div class="aspect-[4/5] overflow-hidden">
              <!-- TODO: Replace with {product.name} photo -->
              <div class="flex h-full w-full items-center justify-center transition-transform duration-500 group-hover:scale-105">
                <span class="font-serif text-5xl text-zinc-300 dark:text-zinc-700">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/70 via-transparent to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6">
              <div class="flex items-end justify-between">
                <h3 class="text-lg font-bold text-white sm:text-xl">{product.name}</h3>
                <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition-all duration-300 group-hover:border-green-400 group-hover:bg-green-500 group-hover:text-zinc-950">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       6. CLIENTS — Marquee logos
       ═══════════════════════════════════════ -->
  <section
    id="clients"
    class="overflow-hidden bg-white py-20 dark:bg-zinc-950 lg:py-24"
    data-snap
    aria-label="Our Clients"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="mb-12 text-center" data-animate="fade-up">
        <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Our Clients</span>
        <h2 class="font-serif text-3xl font-bold text-zinc-900 dark:text-white sm:text-4xl">
          Trusted by UK Retailers
        </h2>
      </div>
    </div>

    <div class="relative" data-animate="fade-up">
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-20 bg-gradient-to-r from-white dark:from-zinc-950 sm:w-32"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-20 bg-gradient-to-l from-white dark:from-zinc-950 sm:w-32"></div>

      <div class="marquee-container flex">
        <div class="marquee-track flex shrink-0 items-center gap-16 pr-16">
          {clients.map((client) => (
            <div class="flex h-14 w-32 items-center justify-center">
              <span class="text-base font-bold text-zinc-300 dark:text-zinc-600">{client}</span>
            </div>
          ))}
        </div>
        <div class="marquee-track flex shrink-0 items-center gap-16 pr-16" aria-hidden="true">
          {clients.map((client) => (
            <div class="flex h-14 w-32 items-center justify-center">
              <span class="text-base font-bold text-zinc-300 dark:text-zinc-600">{client}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       7. CALCULATOR — PriceCalculator embed
       ═══════════════════════════════════════ -->
  <section
    id="calculator"
    class="bg-zinc-50 py-24 dark:bg-zinc-900 lg:py-32"
    data-snap
    aria-label="Price Calculator"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="mb-12 max-w-2xl lg:mb-16" data-animate="fade-up">
        <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Instant Estimate</span>
        <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
          Get a Quick Price Estimate
        </h2>
        <p class="mt-4 text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg">
          Use our interactive calculator for an instant ballpark quote.
          For a detailed quotation, reach out to our sales team.
        </p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white p-6 shadow-lg shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-950 dark:shadow-none sm:p-8" data-animate="fade-up">
        <PriceCalculator />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       8. CTA — Dark cinematic closer
       ═══════════════════════════════════════ -->
  <section
    id="cta"
    class="relative flex min-h-[70vh] items-center overflow-hidden bg-zinc-950 py-24 lg:min-h-[80vh] lg:py-32"
    data-snap
    data-cta-section
    data-cursor-dark
    aria-label="Call to Action"
  >
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-green-500/[0.07] blur-[120px]"></div>
    </div>

    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-green-500/30 to-transparent" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto w-full max-w-[90rem] px-6 text-center sm:px-8 lg:px-12 xl:px-16">

      <div class="mb-8" data-animate="fade-up">
        <span class="inline-flex items-center gap-2 rounded-full border border-green-500/30 bg-green-500/10 px-5 py-2 text-[11px] font-semibold uppercase tracking-[0.25em] text-green-400">
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-green-400"></span>
          Ready to Start
        </span>
      </div>

      <h2 data-cta-title class="font-serif font-bold leading-[0.9] tracking-tight text-white" style="font-size:clamp(2.25rem,6vw,7rem)">
        Let's Build Something Great Together
      </h2>

      <p class="mx-auto mt-8 max-w-lg text-lg leading-relaxed text-zinc-400" data-animate="fade-up">
        Get a detailed, no-obligation quote within 24 hours.
        Our team is ready to bring your vision to life.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row lg:mt-12" data-animate="fade-up">
        <a
          href="/quote/"
          class="inline-flex items-center gap-3 rounded-full bg-green-500 px-10 py-5 text-sm font-bold uppercase tracking-wider text-zinc-950 shadow-2xl shadow-green-500/20 transition-all duration-300 hover:bg-green-400"
          data-cta-button
          data-magnetic
        >
          Get Your Free Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="tel:+923329555786"
          class="inline-flex items-center gap-3 rounded-full border border-zinc-700 px-8 py-5 text-sm font-medium text-zinc-300 transition-all duration-300 hover:border-zinc-500 hover:text-white"
        >
          <svg class="h-4 w-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          Or Call Us
        </a>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  .marquee-container { overflow: hidden; }
  .marquee-track { animation: marquee 30s linear infinite; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-100%); }
  }
  .marquee-container:hover .marquee-track { animation-play-state: paused; }
</style>