---
import Layout from '../layouts/Layout.astro';
import PriceCalculator from '../components/PriceCalculator.astro';

const title = 'Reve Stitching — Premium Garment Manufacturing';
const description =
  '100% export-oriented knitted garment manufacturer based in Faisalabad, Pakistan. 300K+ monthly capacity, 25-50 day lead times, serving UK & EU retailers.';

const steps = [
  {
    num: '01',
    title: 'Design & Development',
    body: 'We collaborate on design concepts, fabric selection, and technical specifications to create the perfect blueprint for your garments.',
    tags: ['CAD Patterns', 'Tech Packs', 'Fabric Sourcing'],
  },
  {
    num: '02',
    title: 'Sampling',
    body: 'Detailed samples for your approval — fit samples, pre-production samples, and size sets — perfected to your exact specifications before production begins.',
    tags: ['Fit Samples', 'PP Samples', 'Size Sets'],
  },
  {
    num: '03',
    title: 'Production',
    body: 'State-of-the-art knitting, cutting, stitching, and finishing lines with real-time quality monitoring ensuring consistency across every piece.',
    tags: ['Knitting', 'Cutting', 'Stitching', 'Finishing'],
  },
  {
    num: '04',
    title: 'Quality Control',
    body: 'Every garment passes through rigorous AQL 2.5 inspection. Fabric testing, measurement checks, and final audits guarantee export-ready quality.',
    tags: ['AQL 2.5', 'Lab Testing', 'Final Audit'],
  },
  {
    num: '05',
    title: 'Shipment',
    body: 'Expertly packed and dispatched. We handle logistics coordination, documentation, and customs compliance for seamless delivery to your warehouse.',
    tags: ['Packing', 'Logistics', 'Documentation'],
  },
];

const products = [
  {
    name: 'T-Shirts',
    image: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Premium cotton t-shirt',
  },
  {
    name: 'Hoodies & Sweatshirts',
    image: 'https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Premium hoodie',
  },
  {
    name: 'Polo Shirts',
    image: 'https://images.unsplash.com/photo-1589310243389-96a5483213a8?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Corporate polo shirt',
  },
  {
    name: 'Joggers & Trousers',
    image: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Athletic joggers',
  },
  {
    name: "Ladies' Wear",
    image: 'https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Ladies fashion garment',
  },
  {
    name: "Kids' Wear",
    image: 'https://images.unsplash.com/photo-1519238263530-99bdd11df2ea?auto=format&fit=crop&w=600&h=750&q=80',
    alt: 'Kids wear collection',
  },
];

const capabilities = [
  {
    title: 'Premium Quality',
    body: 'International quality standards with AQL 2.5 inspection and lab-tested fabrics across every production run.',
  },
  {
    title: 'Fast Turnaround',
    body: '25–50 day lead times from sampling to shipment. Speed without compromise on quality.',
  },
  {
    title: 'Custom Solutions',
    body: 'Full customisation — fabrics, washes, prints, embroidery, labels, and packaging tailored to your brand.',
  },
  {
    title: 'Ethical Production',
    body: 'SEDEX certified. Fair wages, safe working conditions, and sustainable practices across our facility.',
  },
  {
    title: 'UK & EU Focused',
    body: 'Built for UK and European retailers. We understand sizing standards, compliance requirements, and delivery expectations.',
  },
  {
    title: 'Tech-Driven',
    body: 'Modern machinery, digital pattern-making, and ERP-powered production tracking for full transparency.',
  },
];

const clients = [
  'Boohoo',
  'CLOSURE',
  'Yours',
  'Pull & Bear',
  'Daisy Street',
  'MARSHALL ARTIST',
  'Threadbare',
  'HELME',
  'FOREVER CLUB',
];
---

<Layout title={title} description={description}>

  <!-- ═══════════════════════════════════════
       HERO — Light editorial with floating badges
       ═══════════════════════════════════════ -->
  <section
    id="hero"
    class="relative flex min-h-[calc(100dvh-5rem)] flex-col bg-zinc-50 dark:bg-zinc-950"
    data-hero
    aria-label="Hero"
  >
    <div
      class="pointer-events-none absolute inset-0 dark:hidden"
      aria-hidden="true"
      style="background-image:linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 hidden dark:block"
      aria-hidden="true"
      style="background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>

    <!-- Decorative gradient blobs -->
    <div
      class="pointer-events-none absolute right-[8%] top-[12%] h-80 w-80 rounded-full bg-green-500/[0.08] blur-3xl dark:bg-green-500/[0.05]"
      data-hero-deco
      data-float
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-[18%] left-[4%] h-64 w-64 rounded-full bg-emerald-400/[0.06] blur-3xl dark:bg-emerald-400/[0.04]"
      data-hero-deco
      data-float
      data-float-amplitude="12"
      data-float-duration="6"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 mt-auto pb-20 lg:my-auto lg:pb-0" data-hero-content>
      <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

        <div class="mb-6 flex items-center gap-3 lg:mb-8" data-animate="fade-up">
          <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
          <span class="text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">
            Export Garment Manufacturer · Faisalabad
          </span>
        </div>

        <h1>
          <span
            class="block font-serif font-bold leading-[0.88] tracking-tight text-zinc-900 dark:text-white"
            style="font-size:clamp(2.75rem,7vw,8.5rem)"
            data-animate="fade-up"
          >Premium Garment</span>
          <span
            class="block font-serif font-bold leading-[0.88] tracking-tight text-zinc-900 dark:text-white"
            style="font-size:clamp(2.75rem,7vw,8.5rem)"
            data-animate="fade-up"
            data-delay="0.08"
          >Manufacturing for</span>
          <span
            class="block font-serif font-bold leading-[0.88] tracking-tight"
            style="font-size:clamp(2.75rem,7vw,8.5rem)"
            data-animate="fade-up"
            data-delay="0.16"
          ><span class="bg-gradient-to-r from-green-600 to-emerald-500 bg-clip-text text-transparent dark:from-green-400 dark:to-emerald-300">Global Brands</span></span>
        </h1>

        <div class="mt-8 flex flex-col gap-8 lg:mt-12 lg:flex-row lg:items-end lg:justify-between">
          <p
            class="max-w-lg text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg"
            data-animate="fade-up"
            data-delay="0.24"
          >
            100% export-oriented knitted garment manufacturer with 300,000+
            monthly capacity. From concept to container — delivering quality
            UK &amp; EU retailers trust.
          </p>
          <div class="flex items-center gap-4" data-animate="fade-up" data-delay="0.3">
            <a
              href="/quote/"
              class="inline-flex items-center gap-2 rounded-full bg-green-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 dark:bg-green-500 dark:text-zinc-950 dark:hover:bg-green-400"
              data-magnetic
            >
              Get a Quote
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/products/" class="px-5 py-4 text-sm font-medium uppercase tracking-wider text-zinc-400 transition-colors hover:text-zinc-900 dark:text-white/50 dark:hover:text-white">
              View Our Work
            </a>
          </div>
        </div>

        <div class="mt-10 flex items-center gap-3 lg:mt-14" data-animate="fade-up" data-delay="0.36">
          <span class="text-[11px] font-medium uppercase tracking-wider text-zinc-400 dark:text-zinc-500">Trusted by</span>
          <span class="h-px w-4 bg-zinc-300 dark:bg-zinc-700" aria-hidden="true"></span>
          <span class="text-[11px] font-medium text-zinc-400 dark:text-zinc-500">Boohoo · Pull&nbsp;&amp;&nbsp;Bear · Yours Clothing &amp; more</span>
        </div>
      </div>
    </div>

    <!-- Floating stat badges (desktop only) -->
    <div class="pointer-events-none absolute right-[7%] top-[24%] z-10 hidden xl:block" data-float>
      <div class="rounded-2xl border border-zinc-200 bg-white/90 px-5 py-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/80">
        <span class="block text-2xl font-bold text-zinc-900 dark:text-white">300K+</span>
        <span class="text-[11px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Monthly Pieces</span>
      </div>
    </div>
    <div
      class="pointer-events-none absolute right-[14%] top-[50%] z-10 hidden xl:block"
      data-float
      data-float-amplitude="10"
      data-float-duration="5.5"
    >
      <div class="rounded-2xl border border-zinc-200 bg-white/90 px-5 py-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/80">
        <span class="block text-2xl font-bold text-green-600 dark:text-green-400">Since 2019</span>
        <span class="text-[11px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Established</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute inset-x-0 bottom-6 z-10 flex justify-center" aria-hidden="true" data-animate="fade-up" data-delay="0.5">
      <div class="flex flex-col items-center gap-2">
        <span class="text-[10px] font-medium uppercase tracking-[0.35em] text-zinc-400 dark:text-zinc-500">Scroll</span>
        <div class="flex h-9 w-5 items-start justify-center rounded-full border border-zinc-300 p-1 dark:border-zinc-700">
          <div class="h-1.5 w-1.5 animate-bounce rounded-full bg-green-500"></div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       STATS — Light, animated counters
       ═══════════════════════════════════════ -->
  <section
    id="stats"
    class="bg-white py-20 dark:bg-zinc-950 lg:py-24"
    aria-label="Key Statistics"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4 lg:gap-12">

        <div class="text-center" data-animate="fade-up">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="300000">0</span><span class="text-green-600 dark:text-green-400">+</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Monthly Capacity</p>
        </div>

        <div class="text-center" data-animate="fade-up" data-delay="0.1">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="25">0</span>–<span data-counter="50">0</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Days Lead Time</p>
        </div>

        <div class="text-center" data-animate="fade-up" data-delay="0.2">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="150">0</span><span class="text-green-600 dark:text-green-400">+</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Modern Machines</p>
        </div>

        <div class="text-center" data-animate="fade-up" data-delay="0.3">
          <div class="font-serif text-4xl font-bold text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl">
            <span data-counter="9">0</span><span class="text-green-600 dark:text-green-400">+</span>
          </div>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-zinc-500">Brand Partners</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       PROCESS — Pinned scroll with snap
       ═══════════════════════════════════════ -->
  <section
    id="process"
    class="relative bg-zinc-50 dark:bg-zinc-900 lg:overflow-hidden"
    data-pinned-steps
    aria-label="Our Production Process"
  >
    <div class="lg:flex lg:h-screen">

      <!-- LEFT: Info + step indicators -->
      <div class="px-6 py-16 sm:px-8 lg:flex lg:w-[42%] lg:flex-col lg:justify-center lg:px-16 lg:py-0 xl:px-20">
        <div>
          <span class="mb-4 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400" data-animate="fade-up">
            How We Work
          </span>
          <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate="fade-up">
            From Concept<br />to Container
          </h2>
          <p class="mt-5 max-w-md text-base leading-relaxed text-zinc-600 dark:text-zinc-400" data-animate="fade-up">
            A vertically-integrated production workflow built for
            reliability, speed, and quality at every stage.
          </p>

          <div class="mt-10 hidden lg:flex lg:flex-col lg:gap-1">
            {steps.map((s, i) => (
              <div data-step-indicator={i} class="flex items-center gap-3 rounded-lg px-3 py-2.5">
                <span class="step-dot flex h-8 w-8 items-center justify-center rounded-full border text-xs font-bold">
                  {s.num}
                </span>
                <span class="step-label text-sm font-medium text-zinc-600 dark:text-zinc-400">
                  {s.title}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT: Step panels -->
      <div class="relative lg:flex-1" data-steps-container>
        {steps.map((step, i) => (
          <div
            data-step-panel
            class={`px-6 py-14 sm:px-8 lg:flex lg:items-center lg:px-16 lg:py-0 xl:px-20 ${i < steps.length - 1 ? 'border-b border-zinc-200 dark:border-zinc-800 lg:border-0' : ''}`}
          >
            <div class="w-full max-w-xl">
              <div class="mb-5 flex items-center gap-4">
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 font-serif text-xl font-bold text-green-700 dark:bg-green-500/10 dark:text-green-400">
                  {step.num}
                </span>
                <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-700" aria-hidden="true"></div>
              </div>

              <h3 class="font-serif text-2xl font-bold text-zinc-900 dark:text-white sm:text-3xl lg:text-4xl">
                {step.title}
              </h3>

              <p class="mt-4 text-base leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-lg">
                {step.body}
              </p>

              <div class="mt-6 flex flex-wrap gap-2">
                {step.tags.map((tag: string) => (
                  <span class="rounded-full border border-zinc-300 bg-white px-4 py-1.5 text-xs font-medium text-zinc-600 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CAPABILITIES — Bento Grid with 3D tilt
       ═══════════════════════════════════════ -->
  <section
    id="capabilities"
    class="bg-white py-24 dark:bg-zinc-950 lg:py-32"
    aria-label="Our Capabilities"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

      <div class="mb-14 flex flex-col items-start gap-5 lg:mb-20 lg:flex-row lg:items-end lg:justify-between">
        <div data-animate="fade-up">
          <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Capabilities</span>
          <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
            Why Brands<br />Choose Us
          </h2>
        </div>
        <p class="max-w-md text-base leading-relaxed text-zinc-500 dark:text-zinc-400 lg:text-right" data-animate="fade-up" data-delay="0.1">
          Six pillars that define how we manufacture — and why
          UK &amp; EU retailers trust Reve Stitching with their production.
        </p>
      </div>

      <div
        class="grid auto-rows-[minmax(200px,auto)] grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 lg:auto-rows-[minmax(240px,auto)] lg:grid-cols-3 lg:gap-6"
        data-bento
      >
        <!-- Card 1: Premium Quality (tall) -->
        <div
          class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-green-700 to-green-900 p-8 text-white lg:row-span-2 lg:p-10"
          data-bento-item
          data-tilt
        >
          <div class="relative z-10 flex h-full flex-col">
            <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white/10">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            </span>
            <span class="mt-auto font-serif text-6xl font-bold text-white/10 lg:text-8xl" aria-hidden="true">AQL 2.5</span>
            <div class="mt-2">
              <h3 class="text-xl font-bold lg:text-2xl">{capabilities[0].title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{capabilities[0].body}</p>
            </div>
          </div>
        </div>

        <!-- Card 2: Fast Turnaround (wide) -->
        <div class="group overflow-hidden rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:col-span-2 lg:p-10" data-bento-item data-tilt>
          <div class="flex h-full flex-col justify-between sm:flex-row sm:items-end sm:gap-8">
            <div>
              <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 dark:bg-zinc-800">
                <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </span>
              <h3 class="text-xl font-bold text-zinc-900 dark:text-white lg:text-2xl">{capabilities[1].title}</h3>
              <p class="mt-2 max-w-md text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[1].body}</p>
            </div>
            <span class="mt-4 font-serif text-5xl font-bold text-zinc-200 dark:text-zinc-800 sm:mt-0 sm:text-7xl">
              25–50<span class="block text-xs font-sans font-normal uppercase tracking-wider text-zinc-400">days</span>
            </span>
          </div>
        </div>

        <!-- Card 3: Custom Solutions -->
        <div class="rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:p-10" data-bento-item data-tilt>
          <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 dark:bg-zinc-800">
            <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </span>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white lg:text-xl">{capabilities[2].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[2].body}</p>
        </div>

        <!-- Card 4: Ethical Production -->
        <div class="rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:p-10" data-bento-item data-tilt>
          <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 dark:bg-zinc-800">
            <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </span>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white lg:text-xl">{capabilities[3].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[3].body}</p>
        </div>

        <!-- Card 5: UK & EU Focused (wide) -->
        <div class="group relative overflow-hidden rounded-2xl bg-zinc-900 p-8 text-white dark:bg-zinc-800 lg:col-span-2 lg:p-10" data-bento-item data-tilt>
          <div class="relative z-10 flex h-full flex-col justify-between sm:flex-row sm:items-end sm:gap-8">
            <div>
              <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white/10">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.919 17.919 0 01-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
              </span>
              <h3 class="text-xl font-bold lg:text-2xl">{capabilities[4].title}</h3>
              <p class="mt-2 max-w-md text-sm leading-relaxed text-white/60">{capabilities[4].body}</p>
            </div>
            <div class="mt-4 flex gap-2 sm:mt-0" aria-hidden="true">
              <span class="flex items-center gap-2 rounded-full border border-white/20 px-3 py-1 text-xs text-white/60">
                <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span> UK
              </span>
              <span class="flex items-center gap-2 rounded-full border border-white/20 px-3 py-1 text-xs text-white/60">
                <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span> EU
              </span>
            </div>
          </div>
        </div>

        <!-- Card 6: Tech-Driven -->
        <div class="rounded-2xl bg-zinc-100 p-8 dark:bg-zinc-900 lg:p-10" data-bento-item data-tilt>
          <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-zinc-200 dark:bg-zinc-800">
            <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" />
            </svg>
          </span>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-white lg:text-xl">{capabilities[5].title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{capabilities[5].body}</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       PRODUCTS — Horizontal scroll with images
       ═══════════════════════════════════════ -->
  <section
    id="products"
    class="bg-zinc-50 dark:bg-zinc-900"
    aria-label="Product Categories"
  >
    <div class="mx-auto max-w-[90rem] px-6 pt-24 sm:px-8 lg:px-12 lg:pt-32 xl:px-16">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between" data-animate="fade-up">
        <div>
          <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Product Range</span>
          <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
            What We Manufacture
          </h2>
        </div>
        <a href="/products/" class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-green-600 transition-colors hover:text-green-700 dark:text-green-400" data-magnetic>
          View All Products
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>

    <div class="mt-12 lg:mt-16" data-horizontal-scroll>
      <div class="flex flex-col gap-6 px-6 pb-24 sm:px-8 lg:flex-row lg:gap-8 lg:px-12 lg:pb-32 xl:px-16" data-horizontal-track>
        {products.map((product) => (
          <a
            href="/products/"
            class="group relative block flex-shrink-0 overflow-hidden rounded-2xl lg:w-[380px] xl:w-[440px]"
            data-tilt
          >
            <div class="aspect-[4/5] overflow-hidden bg-zinc-200 dark:bg-zinc-800">
              <img
                src={product.image}
                alt={product.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-900/70 via-transparent to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6">
              <div class="flex items-end justify-between">
                <div>
                  <span class="mb-1 block text-[11px] font-semibold uppercase tracking-[0.2em] text-green-400">Category</span>
                  <h3 class="text-lg font-bold text-white sm:text-xl lg:text-2xl">{product.name}</h3>
                </div>
                <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition-all duration-300 group-hover:border-green-400 group-hover:bg-green-500 group-hover:text-zinc-950">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CLIENTS — Marquee logos
       ═══════════════════════════════════════ -->
  <section
    id="clients"
    class="overflow-hidden bg-white py-20 dark:bg-zinc-950 lg:py-24"
    aria-label="Our Clients"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="mb-12 text-center" data-animate="fade-up">
        <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Our Clients</span>
        <h2 class="font-serif text-3xl font-bold text-zinc-900 dark:text-white sm:text-4xl">Trusted by UK &amp; EU Retailers</h2>
      </div>
    </div>

    <div class="relative" data-animate="fade-up" data-delay="0.1">
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-20 bg-gradient-to-r from-white dark:from-zinc-950 sm:w-32"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-20 bg-gradient-to-l from-white dark:from-zinc-950 sm:w-32"></div>

      <div class="marquee-container flex">
        <div class="marquee-track flex shrink-0 items-center gap-16 pr-16">
          {clients.map((client) => (
            <div class="flex h-14 w-36 items-center justify-center">
              <span class="text-lg font-bold text-zinc-300 dark:text-zinc-600">{client}</span>
            </div>
          ))}
        </div>
        <div class="marquee-track flex shrink-0 items-center gap-16 pr-16" aria-hidden="true">
          {clients.map((client) => (
            <div class="flex h-14 w-36 items-center justify-center">
              <span class="text-lg font-bold text-zinc-300 dark:text-zinc-600">{client}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CALCULATOR
       ═══════════════════════════════════════ -->
  <section
    id="calculator"
    class="bg-zinc-50 py-24 dark:bg-zinc-900 lg:py-32"
    aria-label="Price Calculator"
  >
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="mb-12 max-w-2xl lg:mb-16" data-animate="fade-up">
        <span class="mb-3 inline-block text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Instant Estimate</span>
        <h2 class="font-serif text-3xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl">
          Get a Quick Price Estimate
        </h2>
        <p class="mt-4 text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg">
          Use our interactive calculator for an instant ballpark quote.
          For a detailed quotation, reach out to our sales team.
        </p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white p-6 shadow-lg shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-950 dark:shadow-none sm:p-8" data-animate="fade-up" data-delay="0.1">
        <PriceCalculator />
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CTA — Light-mode compatible
       ═══════════════════════════════════════ -->
  <section
    id="cta"
    class="relative flex min-h-[70vh] items-center bg-green-50 py-24 dark:bg-zinc-950 lg:min-h-[80vh] lg:py-32"
    data-cta-section
    aria-label="Call to Action"
  >
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-green-500/30 to-transparent" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto w-full max-w-[90rem] px-6 text-center sm:px-8 lg:px-12 xl:px-16">

      <div class="mb-8" data-animate="fade-up">
        <span class="inline-flex items-center gap-2 rounded-full border border-green-600/30 bg-green-600/10 px-5 py-2 text-[11px] font-semibold uppercase tracking-[0.25em] text-green-700 dark:border-green-500/30 dark:bg-green-500/10 dark:text-green-400">
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-green-600 dark:bg-green-400"></span>
          Ready to Start
        </span>
      </div>

      <h2
        data-cta-title
        class="font-serif font-bold leading-[0.9] tracking-tight text-zinc-900 dark:text-white"
        style="font-size:clamp(2rem,5.5vw,5.5rem)"
      >
        Let's Build Something Great Together
      </h2>

      <p class="mx-auto mt-8 max-w-lg text-lg leading-relaxed text-zinc-600 dark:text-zinc-400" data-animate="fade-up" data-delay="0.1">
        Get a detailed, no-obligation quote within 24 hours.
        Our team is ready to bring your vision to life.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row lg:mt-12" data-animate="fade-up" data-delay="0.15">
        <a
          href="/quote/"
          class="inline-flex items-center gap-3 rounded-full bg-green-600 px-10 py-5 text-sm font-bold uppercase tracking-wider text-white shadow-xl shadow-green-600/20 transition-all duration-300 hover:bg-green-700 dark:bg-green-500 dark:text-zinc-950 dark:shadow-green-500/20 dark:hover:bg-green-400"
          data-cta-button
          data-magnetic
        >
          Get Your Free Quote
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="tel:+923329555786"
          class="inline-flex items-center gap-3 rounded-full border border-zinc-300 px-8 py-5 text-sm font-medium text-zinc-600 transition-all duration-300 hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-white"
        >
          <svg class="h-4 w-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          Or Call Us
        </a>
      </div>

      <p class="mt-8 text-sm text-zinc-500 dark:text-zinc-600" data-animate="fade-up" data-delay="0.2">
        Trusted by UK &amp; EU retailers · No commitment required · Response within 24 hours
      </p>
    </div>
  </section>

</Layout>

<style is:global>
  .marquee-container { overflow: hidden; }
  .marquee-track { animation: marquee 35s linear infinite; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-100%); }
  }
  .marquee-container:hover .marquee-track { animation-play-state: paused; }
</style>