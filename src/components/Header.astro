---
import DarkModeToggle from './DarkModeToggle.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/products/', label: 'Products' },
  { href: '/samples/', label: 'Samples' },
  { href: '/clients/', label: 'Clients' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 bg-white/90 dark:bg-zinc-950/90 backdrop-blur-lg border-b border-transparent transition-all duration-300"
  role="banner"
>
  <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
    <div class="flex items-center justify-between h-20 lg:h-[72px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Reve Stitching — Home">
        <img
          src="/images/icon.png"
          alt=""
          class="w-10 h-10 rounded-lg transition-transform duration-300 group-hover:scale-105"
        />
        <div class="leading-none">
          <span class="font-serif font-bold text-xl text-zinc-900 dark:text-white">Reve</span>
          <span class="font-serif font-bold text-xl text-green-600 dark:text-green-400 ml-0.5">Stitching</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'relative px-4 py-2 text-[13px] font-semibold tracking-wide uppercase rounded-md transition-colors duration-200',
              isActive(link.href)
                ? 'text-green-600 dark:text-green-400 bg-zinc-100 dark:bg-green-500/10'
                : 'text-zinc-600 dark:text-zinc-400 hover:text-green-600 dark:hover:text-green-400 hover:bg-zinc-50 dark:hover:bg-zinc-800',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right Side -->
      <div class="flex items-center gap-2">
        <a
          href="/quote/"
          class="hidden lg:inline-flex items-center gap-2 rounded-full bg-green-600 px-6 py-3 text-xs font-bold uppercase tracking-wider text-white shadow-sm transition-all hover:bg-green-700 dark:bg-green-500 dark:text-zinc-950 dark:hover:bg-green-400"
          data-magnetic
        >
          Get a Quote
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <DarkModeToggle />

        <button
          id="mobile-menu-toggle"
          class="lg:hidden relative w-11 h-11 flex items-center justify-center rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors z-[60]"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <div id="hamburger-icon" class="w-5 h-4 flex flex-col justify-between transition-all duration-300">
            <span class="block h-0.5 w-full bg-zinc-800 dark:bg-zinc-200 rounded transition-all duration-300 origin-center" id="bar1"></span>
            <span class="block h-0.5 w-full bg-zinc-800 dark:bg-zinc-200 rounded transition-all duration-300" id="bar2"></span>
            <span class="block h-0.5 w-3.5 bg-zinc-800 dark:bg-zinc-200 rounded transition-all duration-300 origin-center" id="bar3"></span>
          </div>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Backdrop -->
<div
  id="mobile-menu-backdrop"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 lg:hidden opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 w-full max-w-sm h-full bg-white dark:bg-zinc-950 z-50 lg:hidden translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] shadow-2xl"
  aria-hidden="true"
>
  <div class="flex items-center justify-between h-20 px-6 border-b border-zinc-100 dark:border-zinc-800">
    <div class="flex items-center gap-2.5">
      <img src="/images/icon.png" alt="" class="w-9 h-9 rounded-lg" />
      <div class="leading-none">
        <span class="font-serif font-bold text-lg text-zinc-900 dark:text-white">Reve</span>
        <span class="font-serif font-bold text-lg text-green-600 dark:text-green-400 ml-0.5">Stitching</span>
      </div>
    </div>
    <button
      id="mobile-menu-close"
      class="w-10 h-10 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
      aria-label="Close menu"
    >
      <svg class="text-zinc-600 dark:text-zinc-300" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="flex flex-col h-[calc(100%-80px)] px-6 py-8">
    <nav class="flex flex-col gap-1 flex-1" aria-label="Mobile navigation">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            'flex items-center gap-4 px-4 py-4 rounded-xl text-lg font-semibold transition-all duration-200',
            isActive(link.href)
              ? 'text-green-600 dark:text-green-400 bg-zinc-100 dark:bg-green-500/10'
              : 'text-zinc-700 dark:text-zinc-300 hover:text-green-600 dark:hover:text-green-400 hover:bg-zinc-50 dark:hover:bg-zinc-800/50',
          ]}
          data-mobile-link
          style={`transition-delay: ${i * 50}ms`}
        >
          {link.label}
          {isActive(link.href) && (
            <div class="ml-auto w-2 h-2 rounded-full bg-green-600 dark:bg-green-400"></div>
          )}
        </a>
      ))}
    </nav>

    <div class="pt-6 border-t border-zinc-100 dark:border-zinc-800">
      <a
        href="/quote/"
        class="flex items-center justify-center gap-2 w-full rounded-full bg-green-600 px-6 py-4 text-sm font-bold uppercase tracking-wider text-white transition-all hover:bg-green-700 dark:bg-green-500 dark:text-zinc-950 dark:hover:bg-green-400"
        data-mobile-link
      >
        Get a Quote
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</div>

<!-- Spacer -->
<div class="h-20 lg:h-[72px]" aria-hidden="true"></div>

<script>
  function initMobileMenu() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    let isOpen = false;

    const handleScroll = () => {
      if (!header) return;
      if (window.scrollY > 20) {
        header.classList.add('shadow-lg', 'shadow-black/[0.04]', 'border-zinc-200/60', 'dark:border-zinc-800/60');
      } else {
        header.classList.remove('shadow-lg', 'shadow-black/[0.04]', 'border-zinc-200/60', 'dark:border-zinc-800/60');
      }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    function openMenu() {
      isOpen = true;
      toggle?.setAttribute('aria-expanded', 'true');
      menu?.setAttribute('aria-hidden', 'false');
      menu?.classList.remove('translate-x-full');
      menu?.classList.add('translate-x-0');
      backdrop?.classList.remove('opacity-0', 'pointer-events-none');
      backdrop?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      menu?.classList.add('translate-x-full');
      menu?.classList.remove('translate-x-0');
      backdrop?.classList.add('opacity-0', 'pointer-events-none');
      backdrop?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    }

    toggle?.addEventListener('click', () => { if (isOpen) closeMenu(); else openMenu(); });
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);
    menu?.querySelectorAll('[data-mobile-link]').forEach((link) => { link.addEventListener('click', closeMenu); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeMenu(); });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>