---
/**
 * src/components/Header.astro
 * FIXED: Mobile menu with proper background, better styling, smooth animations.
 */

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/products/', label: 'Products' },
  { href: '/clients/', label: 'Clients' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur-lg border-b border-transparent transition-all duration-300"
  role="banner"
>
  <div class="container-main section-padding">
    <div class="flex items-center justify-between h-20 lg:h-[72px]">

      <!-- ━━━ Logo ━━━ -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Reve Stitching — Home">
        <img 
          src="/images/icon.png" 
          alt="" 
          class="w-10 h-10 rounded-lg transition-transform duration-300 group-hover:scale-105"
        />
        <div class="leading-none">
          <span class="font-serif font-bold text-xl text-zinc-900">Reve</span>
          <span class="font-serif font-bold text-xl text-primary ml-0.5">Stitching</span>
        </div>
      </a>

      <!-- ━━━ Desktop Navigation ━━━ -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'relative px-4 py-2 text-[13px] font-semibold tracking-wide uppercase rounded-md transition-colors duration-200',
              isActive(link.href)
                ? 'text-primary bg-surface'
                : 'text-zinc-600 hover:text-primary hover:bg-surface/60',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- ━━━ Desktop CTA + Mobile Toggle ━━━ -->
      <div class="flex items-center gap-3">
        <a
          href="/contact/"
          class="hidden lg:inline-flex btn-primary !py-3 !px-6 !text-xs"
          data-magnetic
        >
          Get a Quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Hamburger toggle (mobile) -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden relative w-11 h-11 flex items-center justify-center rounded-lg hover:bg-zinc-100 transition-colors z-[60]"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <div id="hamburger-icon" class="w-5 h-4 flex flex-col justify-between transition-all duration-300">
            <span class="block h-0.5 w-full bg-zinc-800 rounded transition-all duration-300 origin-center" id="bar1"></span>
            <span class="block h-0.5 w-full bg-zinc-800 rounded transition-all duration-300" id="bar2"></span>
            <span class="block h-0.5 w-3.5 bg-zinc-800 rounded transition-all duration-300 origin-center" id="bar3"></span>
          </div>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- ━━━ Mobile Menu Overlay (Full Screen) ━━━ -->
<div
  id="mobile-menu-backdrop"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 lg:hidden opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<div
  id="mobile-menu"
  class="fixed top-0 right-0 w-full max-w-sm h-full bg-white z-50 lg:hidden translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] shadow-2xl"
  aria-hidden="true"
>
  <!-- Menu Header -->
  <div class="flex items-center justify-between h-20 px-6 border-b border-zinc-100">
    <div class="flex items-center gap-2.5">
      <img 
        src="/images/icon.png" 
        alt="" 
        class="w-9 h-9 rounded-lg"
      />
      <div class="leading-none">
        <span class="font-serif font-bold text-lg text-zinc-900">Reve</span>
        <span class="font-serif font-bold text-lg text-primary ml-0.5">Stitching</span>
      </div>
    </div>
    
    <!-- Close button -->
    <button
      id="mobile-menu-close"
      class="w-10 h-10 rounded-lg bg-zinc-100 flex items-center justify-center hover:bg-zinc-200 transition-colors"
      aria-label="Close menu"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Menu Content -->
  <div class="flex flex-col h-[calc(100%-80px)] px-6 py-8">
    <!-- Navigation Links -->
    <nav class="flex flex-col gap-1 flex-1" aria-label="Mobile navigation">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            'flex items-center gap-4 px-4 py-4 rounded-xl text-lg font-semibold transition-all duration-200',
            isActive(link.href)
              ? 'text-primary bg-surface'
              : 'text-zinc-700 hover:text-primary hover:bg-surface/50',
          ]}
          data-mobile-link
          style={`transition-delay: ${i * 50}ms`}
        >
          <!-- Icon for each link -->
          {link.href === '/' && (
            <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
          )}
          {link.href === '/about/' && (
            <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
          )}
          {link.href === '/products/' && (
            <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>
          )}
          {link.href === '/clients/' && (
            <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          )}
          {link.href === '/contact/' && (
            <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          )}
          
          {link.label}

          <!-- Active indicator -->
          {isActive(link.href) && (
            <div class="ml-auto w-2 h-2 rounded-full bg-primary"></div>
          )}
        </a>
      ))}
    </nav>

    <!-- Bottom Section -->
    <div class="pt-6 border-t border-zinc-100 space-y-4">
      <!-- CTA Button -->
      <a href="/contact/" class="btn-primary w-full text-center" data-mobile-link>
        Get a Quote
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Social Links -->
      <div class="flex items-center gap-3 px-2 pt-2">
        {['LinkedIn', 'Facebook', 'Instagram'].map((social) => (
          <a
            href="#"
            class="w-9 h-9 rounded-full bg-zinc-100 flex items-center justify-center text-zinc-400 hover:bg-primary hover:text-white transition-all duration-200"
            aria-label={social}
          >
            {social === 'LinkedIn' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            )}
            {social === 'Facebook' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            )}
            {social === 'Instagram' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z"/></svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<!-- Spacer -->
<div class="h-20 lg:h-[72px]" aria-hidden="true"></div>

<script>
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    let isOpen = false;

    // Scroll shadow on header
    const handleScroll = () => {
      if (!header) return;
      if (window.scrollY > 20) {
        header.classList.add('shadow-lg', 'shadow-black/[0.04]', 'border-zinc-200/60');
      } else {
        header.classList.remove('shadow-lg', 'shadow-black/[0.04]', 'border-zinc-200/60');
      }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Open/Close menu
    function openMenu() {
      isOpen = true;
      toggle?.setAttribute('aria-expanded', 'true');
      menu?.setAttribute('aria-hidden', 'false');
      menu?.classList.remove('translate-x-full');
      menu?.classList.add('translate-x-0');
      backdrop?.classList.remove('opacity-0', 'pointer-events-none');
      backdrop?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      menu?.classList.add('translate-x-full');
      menu?.classList.remove('translate-x-0');
      backdrop?.classList.add('opacity-0', 'pointer-events-none');
      backdrop?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
    }

    // Toggle button
    toggle?.addEventListener('click', () => {
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close button
    closeBtn?.addEventListener('click', closeMenu);

    // Clicking backdrop closes menu
    backdrop?.addEventListener('click', closeMenu);

    // Close menu when clicking a link
    menu?.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });
  });
</script>