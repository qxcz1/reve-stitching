---
/**
 * src/components/ProductCard.astro
 * Reusable product card with image, rating, features toggle, MOQ badge.
 */

interface Props {
  name: string;
  image: string;
  rating: number;
  moq: number;
  features: string[];
  index?: number;
}

const { name, image, rating, moq, features, index = 0 } = Astro.props;

// Generate star display
const fullStars = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
---

<article class="group bg-white rounded-2xl border border-zinc-100 overflow-hidden hover:shadow-2xl hover:shadow-primary/8 hover:-translate-y-1 transition-all duration-500">
  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden bg-zinc-100">
    <img
      src={image}
      alt={name}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
    />

    <!-- MOQ Badge -->
    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm rounded-full px-3 py-1.5 text-[11px] font-bold text-primary uppercase tracking-wider">
      MOQ: {moq} pcs
    </div>

    <!-- Hover Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
      <a
        href="/contact/"
        class="w-full text-center bg-white text-primary font-semibold text-sm py-3 rounded-lg hover:bg-zinc-50 transition-colors"
      >
        Inquire Now
      </a>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <!-- Rating -->
    <div class="flex items-center gap-1.5 mb-3">
      <div class="flex items-center gap-0.5">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg
            class={`w-4 h-4 ${i < fullStars ? 'text-amber-400' : i === fullStars && hasHalf ? 'text-amber-400' : 'text-zinc-200'}`}
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <span class="text-sm font-semibold text-zinc-700">{rating}</span>
    </div>

    <!-- Name -->
    <h3 class="text-lg font-bold text-zinc-900 mb-3 leading-snug group-hover:text-primary transition-colors duration-300">
      {name}
    </h3>

    <!-- Features -->
    <div class="product-features">
      <ul class="space-y-1.5">
        {features.map((feature) => (
          <li class="flex items-center gap-2 text-sm text-zinc-500">
            <svg class="w-4 h-4 text-primary-light shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
            </svg>
            {feature}
          </li>
        ))}
      </ul>
    </div>
  </div>
</article>