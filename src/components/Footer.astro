---
/**
 * src/components/Footer.astro
 * Site-wide footer with company info, navigation, product links,
 * contact details, certification badges, and copyright.
 */

const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About Us' },
  { href: '/products/', label: 'Products' },
  { href: '/clients/', label: 'Our Clients' },
  { href: '/contact/', label: 'Contact' },
];

const productLinks = [
  'Premium T-Shirts',
  'Corporate Polo Shirts',
  'Hoodies & Sweatshirts',
  'Athletic Joggers',
  'Ladies\' Wear',
  'Kids\' Wear',
];

const certifications = ['SEDEX', 'SGS', 'BCI', 'GOTS', 'OCS', 'ISO 9001'];
---

<footer class="bg-zinc-950 text-zinc-400 pt-20 pb-8" role="contentinfo">
  <div class="container-main section-padding">

    <!-- ━━━ Top Grid ━━━ -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 pb-16 border-b border-zinc-800">

      <!-- Column 1 — About -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-5">
  <img 
    src="/images/icon.png" 
    alt="" 
    class="w-10 h-10 rounded-lg"
  />
  <span class="font-serif font-bold text-lg text-white">Reve <span class="text-primary-light">Stitching</span></span>
</a>
        <p class="text-sm leading-relaxed mb-6 max-w-xs">
          Leading 100% export-oriented knitted garment manufacturer.
          Strategically located in Faisalabad, Pakistan's textile heartland.
        </p>
        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          {['linkedin', 'facebook', 'instagram'].map((social) => (
            <a
              href="#"
              class="w-9 h-9 rounded-full border border-zinc-700 flex items-center justify-center text-zinc-500 hover:border-primary hover:text-primary-light transition-colors duration-200"
              aria-label={`Follow us on ${social}`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                {social === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                {social === 'facebook' && <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>}
                {social === 'instagram' && <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z"/>}
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2 — Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-primary-light transition-colors duration-200 inline-flex items-center gap-1.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary-light/40"><path d="m9 18 6-6-6-6"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3 — Products -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">Our Products</h3>
        <ul class="space-y-3">
          {productLinks.map((product) => (
            <li>
              <a href="/products/" class="text-sm hover:text-primary-light transition-colors duration-200 inline-flex items-center gap-1.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary-light/40"><path d="m9 18 6-6-6-6"/></svg>
                {product}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4 — Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-light mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            <span class="text-sm leading-relaxed">Chak No. 196/R.B, Ghona Road,<br/>Faisalabad (38000), Pakistan</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-light mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            <div class="text-sm space-y-1">
              <a href="mailto:info@revestitching.com" class="block hover:text-primary-light transition-colors">info@revestitching.com</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-light mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm">Mon–Sat: 8 AM – 6 PM<br/>Sunday: Closed</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- ━━━ Certification Badges ━━━ -->
    <div class="flex flex-wrap items-center justify-center gap-4 py-8 border-b border-zinc-800">
      {certifications.map((cert) => (
        <span class="px-4 py-1.5 text-[11px] font-bold tracking-widest uppercase text-zinc-500 border border-zinc-800 rounded-full">
          {cert}
        </span>
      ))}
    </div>

    <!-- ━━━ Copyright ━━━ -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 text-xs text-zinc-600">
      <p>&copy; {currentYear} Reve Stitching. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="#" class="hover:text-zinc-400 transition-colors">Privacy Policy</a>
        <span class="text-zinc-800">|</span>
        <a href="#" class="hover:text-zinc-400 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>