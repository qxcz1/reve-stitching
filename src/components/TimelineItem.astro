---
/**
 * src/components/TimelineItem.astro
 * Individual timeline entry with year badge, title, and description.
 */

interface Props {
  year: string;
  title: string;
  description: string;
  isLast?: boolean;
}

const { year, title, description, isLast = false } = Astro.props;
---

<div class="relative pl-10 md:pl-14 pb-12 group" data-animate="fade-up">
  <!-- Vertical Line -->
  {!isLast && (
    <div class="absolute left-[17px] md:left-[25px] top-8 bottom-0 w-px bg-border group-hover:bg-primary-light/30 transition-colors duration-500"></div>
  )}

  <!-- Dot -->
  <div class="absolute left-2 md:left-3.5 top-1 w-[14px] h-[14px] rounded-full border-[3px] border-primary bg-white group-hover:bg-primary group-hover:scale-125 transition-all duration-300 z-10"></div>

  <!-- Content -->
  <div class="bg-white border border-zinc-100 rounded-xl p-6 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-500">
    <span class="inline-block text-xs font-bold tracking-widest uppercase text-primary bg-surface px-3 py-1 rounded-full mb-3">
      {year}
    </span>
    <h3 class="text-lg font-bold text-zinc-900 mb-2">{title}</h3>
    <p class="text-sm text-zinc-500 leading-relaxed">{description}</p>
  </div>
</div>