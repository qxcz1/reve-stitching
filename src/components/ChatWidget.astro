    // ━━━ Storage Helpers ━━━
    interface ChatMsg {
      text: string;
      sender: 'bot' | 'user' | 'admin' | 'system';
      time: string;
    }

    function ss(key: string, val?: string): string | null {
      try {
        if (val !== undefined) { sessionStorage.setItem(key, val); return val; }
        return sessionStorage.getItem(key);
      } catch { return null; }
    }

    function getMode(): 'bot' | 'live' { return (ss(SK.mode) as 'bot' | 'live') || 'bot'; }
    function setMode(m: 'bot' | 'live') { ss(SK.mode, m); }
    function getSessionId(): string | null { return ss(SK.sessionId); }
    function getVisitorToken(): string {
      let t = ss(SK.visitorToken);
      if (!t) { t = crypto.randomUUID(); ss(SK.visitorToken, t); }
      return t;
    }

    function saveMsg(text: string, sender: ChatMsg['sender']) {
      try {
        const h: ChatMsg[] = JSON.parse(ss(SK.messages) || '[]');
        h.push({ text, sender, time: formatTime() });
        ss(SK.messages, JSON.stringify(h));
      } catch {}
    }

    function getMsgHistory(): ChatMsg[] {
      try { return JSON.parse(ss(SK.messages) || '[]'); } catch { return []; }
    }

    // ━━━ Formatters ━━━
    function formatTime(): string {
      return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function formatMessage(text: string): string {
      return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="text-primary underline hover:text-primary-light">$1</a>')
        .replace(/\n/g, '<br/>');
    }

    // ━━━ Render Message ━━━
    function renderMessage(text: string, sender: ChatMsg['sender'], time?: string): void {
      if (!messages) return;
      const t = time || formatTime();
      const div = document.createElement('div');

      if (sender === 'system') {
        div.className = 'chat-msg flex justify-center';
        div.innerHTML = `<div class="px-4 py-2 bg-zinc-100 rounded-full text-xs text-zinc-500">${formatMessage(text)}</div>`;
      } else if (sender === 'user') {
        div.className = 'chat-msg flex justify-end';
        div.innerHTML = `
          <div class="max-w-[80%]">
            <div class="bg-primary text-white rounded-2xl rounded-tr-md px-4 py-3 text-sm leading-relaxed">${formatMessage(text)}</div>
            <span class="text-[10px] text-zinc-400 mt-1 block text-right pr-1">${t}</span>
          </div>`;
      } else {
        // bot or admin
        const icon = sender === 'admin' ? adminIconSvg : botIconSvg;
        const iconBg = sender === 'admin' ? 'bg-green-100' : 'bg-primary/10';
        div.className = 'chat-msg flex justify-start';
        div.innerHTML = `
          <div class="flex gap-2.5 max-w-[85%]">
            <div class="w-7 h-7 rounded-full ${iconBg} flex items-center justify-center shrink-0 mt-1">${icon}</div>
            <div>
              ${sender === 'admin' ? '<span class="text-[10px] text-green-600 font-medium mb-0.5 block">Team Member</span>' : ''}
              <div class="bg-zinc-100 rounded-2xl rounded-tl-md px-4 py-3 text-sm text-zinc-700 leading-relaxed">${formatMessage(text)}</div>
              <span class="text-[10px] text-zinc-400 mt-1 block pl-1">${t}</span>
            </div>
          </div>`;
      }

      messages.appendChild(div);
    }

    function addMessage(text: string, sender: ChatMsg['sender']): void {
      renderMessage(text, sender);
      saveMsg(text, sender);
      if (messages) messages.scrollTop = messages.scrollHeight;
    }

    // ━━━ Typing Indicator ━━━
    function showTyping(): void {
      if (!messages) return;
      const div = document.createElement('div');
      div.id = 'typing-indicator';
      div.className = 'chat-msg flex justify-start';
      div.innerHTML = `
        <div class="flex gap-2.5">
          <div class="w-7 h-7 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-1">${botIconSvg}</div>
          <div class="bg-zinc-100 rounded-2xl rounded-tl-md px-4 py-3 flex items-center gap-1.5">
            <div class="w-2 h-2 bg-zinc-400 rounded-full typing-dot"></div>
            <div class="w-2 h-2 bg-zinc-400 rounded-full typing-dot"></div>
            <div class="w-2 h-2 bg-zinc-400 rounded-full typing-dot"></div>
          </div>
        </div>`;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function hideTyping(): void {
      document.getElementById('typing-indicator')?.remove();
    }

    // ━━━ Quick Replies ━━━
    function showQuickReplies(replies?: string[]): void {
      if (!quickContainer) return;
      quickContainer.innerHTML = '';
      const items = replies
        ? replies.map(r => ({ label: r, value: quickReplyMap[r] || r }))
        : defaultQuickReplies;

      items.forEach(item => {
        if (item.value?.startsWith('__LINK__')) {
          const a = document.createElement('a');
          a.href = item.value.replace('__LINK__', '');
          a.className = 'inline-flex items-center gap-1 px-3 py-2 bg-surface border border-border rounded-full text-xs font-medium text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 cursor-pointer';
          a.textContent = `🔗 ${item.label}`;
          quickContainer.appendChild(a);
          return;
        }
        const btn = document.createElement('button');
        btn.className = 'px-3 py-2 bg-surface border border-border rounded-full text-xs font-medium text-zinc-600 hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 cursor-pointer';
        btn.textContent = item.label;
        btn.addEventListener('click', () => handleUserMessage(item.value || item.label));
        quickContainer.appendChild(btn);
      });
    }

    // ━━━ Bot Response Finder ━━━
    function findBotResponse(message: string): { answer: string; followUp?: string[] } {
      const lower = message.toLowerCase();
      let bestMatch: { answer: string; followUp?: string[] } | null = null;
      let bestScore = 0;

      for (const [keywords, response] of Object.entries(botResponses)) {
        const keywordList = keywords.split('|');
        let score = 0;
        for (const kw of keywordList) {
          if (kw.length <= 3) {
            if (new RegExp(`\\b${kw}\\b`, 'i').test(lower)) score += kw.length;
          } else {
            if (lower.includes(kw)) score += kw.length;
          }
        }
        if (score > bestScore) { bestScore = score; bestMatch = response; }
      }

      if (bestMatch) return bestMatch;
      return {
        answer: "Thanks for your message! I'm not sure about that specific question, but our team can definitely help.\n\nYou can:\n• Ask me about **products, MOQ, quality, or certifications**\n• Click **\"Talk to a human\"** below for direct assistance\n• Visit our **[contact page](/contact/)** for detailed inquiries",
        followUp: ['Product range', 'MOQ details', 'Request human', 'Get a quote'],
      };
    }

