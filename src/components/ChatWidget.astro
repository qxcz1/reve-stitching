            <input id="live-email" type="email" placeholder="Your email" class="w-full px-3 py-2 border border-zinc-200 rounded-lg text-xs focus:outline-none focus:border-primary" />
            <div class="flex gap-2">
              <button id="live-connect-btn" class="flex-1 px-3 py-2 bg-primary text-white rounded-lg text-xs font-medium hover:bg-primary-light transition-colors">Connect Now</button>
              <button id="live-skip-btn" class="px-3 py-2 border border-zinc-200 rounded-lg text-xs text-zinc-600 hover:bg-zinc-50 transition-colors">Skip</button>
            </div>
          </div>`;

        const connect = (name?: string, email?: string) => {
          createLiveSession(name, email);
        };

        document.getElementById('live-connect-btn')?.addEventListener('click', () => {
          const name = (document.getElementById('live-name') as HTMLInputElement)?.value;
          const email = (document.getElementById('live-email') as HTMLInputElement)?.value;
          connect(name, email);
        });

        document.getElementById('live-skip-btn')?.addEventListener('click', () => {
          connect();
        });
      }
    }

    async function createLiveSession(name?: string, email?: string): Promise<void> {
      if (quickContainer) quickContainer.innerHTML = '';

      const visitorToken = getVisitorToken();

      try {
        const res = await fetch('/api/chat/session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            visitorToken,
            visitorName: name || null,
            visitorEmail: email || null,
          }),
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.error);

        ss(SK.sessionId, data.sessionId);
        setMode('live');

        addMessage("You're now connected! 🟢 A team member will join this chat shortly.\n\nYou can start typing your questions — they'll see your messages when they connect.\n\n🕐 Typical response: Within a few minutes during business hours (Mon-Sat, 8AM-6PM PKT).", 'system');

        startPolling();
        startHeartbeat();

      } catch (e) {
        addMessage("Sorry, I couldn't connect you right now. Please try emailing us at **haroon@revestitching.com** instead.", 'bot');
        showQuickReplies(['Get a quote', 'Contact team']);
      }
    }

    // ━━━ Live Chat: Send Message ━━━
    async function sendLiveMessage(text: string): Promise<void> {
      addMessage(text, 'user');

      const sessionId = getSessionId();
      const visitorToken = getVisitorToken();

      if (!sessionId) return;

      try {
        await fetch('/api/chat/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId, visitorToken, message: text }),
        });
      } catch (e) {
        console.warn('Failed to send live message:', e);
      }
    }

    // ━━━ Live Chat: Poll for Admin Messages ━━━
       function startPolling(): void {
      if (pollInterval) return;

      pollInterval = setInterval(async () => {
        const sessionId = getSessionId();
        const visitorToken = getVisitorToken();
        if (!sessionId) return;

        try {
          const res = await fetch(
            `/api/chat/poll?session=${sessionId}&token=${visitorToken}&after=${encodeURIComponent(lastPollTimestamp)}`
          );
          const data = await res.json();

          if (data.messages && data.messages.length > 0) {
            data.messages.forEach((msg: any) => {
              // ✅ Skip messages we already showed
              if (seenMessageIds.has(msg.id)) return;
              seenMessageIds.add(msg.id);

              // ✅ Update timestamp to latest message
              lastPollTimestamp = msg.created_at;

              // ✅ Render but DON'T save to sessionStorage (prevent duplicates)
              renderMessage(msg.message, 'admin', new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
              if (messages) messages.scrollTop = messages.scrollHeight;

              // ✅ Save separately with ID tracking
              try {
                const h: ChatMsg[] = JSON.parse(ss(SK.messages) || '[]');
                // Check if already saved
                const alreadySaved = h.some(m => m.text === msg.message && m.sender === 'admin');
                if (!alreadySaved) {
                  h.push({ text: msg.message, sender: 'admin', time: new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) });
                  ss(SK.messages, JSON.stringify(h));
                }
              } catch {}
            });
          }

          // Check if session was closed by admin
          if (data.sessionStatus === 'closed') {
            stopPolling();
            stopHeartbeat();
            addMessage("This chat session has ended. Thank you for chatting with us! 👋", 'system');
            setMode('bot');

            // Clear all chat data
            sessionStorage.removeItem(SK.sessionId);
            sessionStorage.removeItem(SK.messages);
            sessionStorage.removeItem(SK.hasOpened);
            sessionStorage.removeItem(SK.wasOpen);
            sessionStorage.removeItem(SK.mode);

            // Show fresh quick replies
            showQuickReplies(['Get a quote', 'Product range', 'Contact team']);
          }
        } catch (e) {
          console.warn('Poll error:', e);
        }
      }, 3000);
    }

    // ━━━ Heartbeat: Keep session alive ━━━
    let heartbeatInterval: ReturnType<typeof setInterval> | null = null;

    function startHeartbeat(): void {
      if (heartbeatInterval) return;
      heartbeatInterval = setInterval(async () => {
        const sessionId = getSessionId();
        const visitorToken = getVisitorToken();
        if (!sessionId || getMode() !== 'live') {
          stopHeartbeat();
          return;
        }
        try {
          await fetch('/api/chat/heartbeat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sessionId, visitorToken }),
          });
        } catch {}
      }, 15000); // Every 15 seconds
    }

    function stopHeartbeat(): void {
      if (heartbeatInterval) { clearInterval(heartbeatInterval); heartbeatInterval = null; }
    }

    function stopPolling(): void {
      if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
    }

    // ━━━ Handle User Message ━━━
    function handleUserMessage(text: string): void {
      const mode = getMode();

      if (mode === 'live') {
        sendLiveMessage(text);
        return;
      }

      // Bot mode
      addMessage(text, 'user');
      if (quickContainer) quickContainer.innerHTML = '';
      showTyping();

      const delay = 800 + Math.random() * 700;
      setTimeout(() => {
        hideTyping();
        const response = findBotResponse(text);

        // Special: human request
        if (response.answer === '__REQUEST_HUMAN__') {
          requestHuman();
          return;
        }

        addMessage(response.answer, 'bot');
        setTimeout(() => showQuickReplies(response.followUp), 300);
      }, delay);
    }

    // ━━━ Restore History ━━━
    function restoreHistory(): void {
      if (!messages) return;
      const history = getMsgHistory();
      if (history.length === 0) return;

      messages.innerHTML = '';
      history.forEach(msg => renderMessage(msg.text, msg.sender, msg.time));
      messages.scrollTop = messages.scrollHeight;
      notification?.classList.add('hidden');
    }

    // ━━━ Open/Close Chat ━━━
    function openChat(): void {
      isOpen = true;
      ss(SK.wasOpen, 'true');
      chatWindow?.classList.remove('opacity-0', 'scale-95', 'translate-y-4', 'pointer-events-none');
      chatWindow?.classList.add('opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
      chatWindow?.setAttribute('aria-hidden', 'false');
      iconOpen?.classList.add('opacity-0', 'rotate-90', 'scale-0');
      iconClose?.classList.remove('opacity-0');
      iconClose?.classList.add('rotate-0', 'scale-100');
      notification?.classList.add('hidden');

      if (!ss(SK.hasOpened)) {
        ss(SK.hasOpened, 'true');
        setTimeout(() => {
          addMessage("Hello! 👋 Welcome to **Reve Stitching**!\n\nI'm your virtual assistant. I can help you with:\n\n• Product information & MOQ\n• Pricing & quotes\n• Quality standards & certifications\n• Lead times & delivery\n\nHow can I help you today?", 'bot');
          showQuickReplies();
        }, 400);
           } else {
        // Don't show quick replies during live chat
        if (getMode() !== 'live') {
          const history = getMsgHistory();
          if (history.length > 0) {
            const lastBot = [...history].reverse().find(m => m.sender === 'bot');
            if (lastBot) {
              const r = findBotResponse(lastBot.text);
              if (r.answer !== '__REQUEST_HUMAN__') showQuickReplies(r.followUp);
            } else {
              showQuickReplies();
            }
          }
        }
      }
      input?.focus();
    }

    function closeChat(): void {
      isOpen = false;
      ss(SK.wasOpen, 'false');
      chatWindow?.classList.add('opacity-0', 'scale-95', 'translate-y-4', 'pointer-events-none');
      chatWindow?.classList.remove('opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
      chatWindow?.setAttribute('aria-hidden', 'true');
      iconOpen?.classList.remove('opacity-0', 'rotate-90', 'scale-0');
      iconClose?.classList.add('opacity-0');
      iconClose?.classList.remove('rotate-0', 'scale-100');
    }

    // ━━━ Init ━━━
    function initChat(): void {
      if (ss(SK.hasOpened) && getMsgHistory().length > 0) {
        restoreHistory();
        notification?.classList.add('hidden');

        // Resume live mode polling
        if (getMode() === 'live' && getSessionId()) {
          startPolling();
          startHeartbeat();
        }

        if (ss(SK.wasOpen) === 'true') openChat();
      }
    }

        // ━━━ Event Listeners ━━━
    toggle?.addEventListener('click', () => { isOpen ? closeChat() : openChat(); });
    minimize?.addEventListener('click', closeChat);

    // NEW: Reset chat button listener
    const resetBtn = document.getElementById('chat-reset-btn');
        resetBtn?.addEventListener('click', () => {
      if (!confirm('Start a new chat? This will clear your current conversation.')) return;
      
      // Stop polling if in live mode
      stopPolling();
      stopHeartbeat();
      
      // Close the live session if active
      const sessionId = getSessionId();
      const visitorToken = getVisitorToken();
      if (sessionId && getMode() === 'live') {
        navigator.sendBeacon('/api/chat/close', JSON.stringify({
          sessionId,
          visitorToken,
        }));
      }
      
      // Clear everything from sessionStorage
      sessionStorage.removeItem(SK.messages);
      sessionStorage.removeItem(SK.hasOpened);
      sessionStorage.removeItem(SK.wasOpen);
      sessionStorage.removeItem(SK.mode);
      sessionStorage.removeItem(SK.sessionId);
      sessionStorage.removeItem(SK.visitorToken);
      
      // Reload page to start fresh
      window.location.reload();
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input?.value?.trim();
      if (!text) return;
      handleUserMessage(text);
      if (input) {
        input.value = '';
        input.style.height = 'auto';
      }
    });

    // Shift+Enter for new line, Enter to send
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form?.dispatchEvent(new Event('submit'));
      }
    });

    // Auto-resize textarea
    input?.addEventListener('input', () => {
      if (!input) return;
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    });

    humanBtn?.addEventListener('click', () => {
      handleUserMessage('I want to talk to a human representative');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeChat();
    });

    // ━━━ Close session on tab close ━━━
    window.addEventListener('beforeunload', () => {
      const sessionId = getSessionId();
      const visitorToken = getVisitorToken();
      if (sessionId && getMode() === 'live') {
        // Use sendBeacon for reliability (works even during page unload)
        navigator.sendBeacon('/api/chat/close', JSON.stringify({
          sessionId,
          visitorToken,
        }));
      }
    });

    // ━━━ Boot ━━━
    initChat();

  });
</script>