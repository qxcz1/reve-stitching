---
/**
 * src/components/StatsBar.astro
 * Animated statistics strip — dark green background.
 * FIXED: "Since 2019" and text-based stats use display property (no counter).
 *        Only numeric values (300K, 150) use counter animation.
 */

 const stats = [
  { label: 'SEDEX Compliant', display: 'SEDEX', icon: 'shield' },
  { label: 'Monthly Capacity', value: 300000, suffix: '+', icon: 'chart' },
  { label: 'Modern Machines', value: 150, suffix: '+', icon: 'cog' },
  { label: 'Established', display: 'Since 2019', icon: 'calendar' },
  { label: 'Quality Standards', display: 'AQL 1.5-4.0', icon: 'check' },
];
---

<section class="bg-primary-dark relative overflow-hidden" aria-label="Key statistics">
  <!-- Subtle dot pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="container-main section-padding relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 py-12 lg:py-14">
      {stats.map((stat) => (
        <div class="text-center" data-animate="fade-up">
          <!-- Icon -->
          <div class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-white/10 mb-3">
            {stat.icon === 'shield' && (
              <svg class="w-5 h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            )}
            {stat.icon === 'chart' && (
              <svg class="w-5 h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
            )}
            {stat.icon === 'cog' && (
              <svg class="w-5 h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a6.759 6.759 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            )}
            {stat.icon === 'calendar' && (
              <svg class="w-5 h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            )}
            {stat.icon === 'check' && (
              <svg class="w-5 h-5 text-primary-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            )}
          </div>

          <!-- Value: static display OR animated counter -->
          {stat.display ? (
            <div class="text-2xl md:text-3xl font-bold text-white mb-1 tracking-tight">
              {stat.display}
            </div>
          ) : (
            <div
              class="text-2xl md:text-3xl font-bold text-white mb-1 tracking-tight"
              data-counter={stat.value}
              data-suffix={stat.suffix || ''}
            >
              0
            </div>
          )}

          <!-- Label -->
          <p class="text-xs text-green-200/70 font-medium uppercase tracking-wider">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>