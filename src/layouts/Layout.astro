---
/**
 * src/layouts/Layout.astro
 * Main HTML shell — wraps every page with <head>, fonts, header, footer,
 * global scripts (GSAP / Lenis), and structured data.
 */

import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Reve Stitching — Leading 100% export-oriented knitted garment manufacturer in Faisalabad, Pakistan. 300K+ monthly capacity, SEDEX compliant, AQL 1.5-4.0.',
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Reve Stitching</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Reve Stitching`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Reve Stitching" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Reve Stitching`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts — preconnect + load Inter & Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data — ManufacturingBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ManufacturingBusiness",
      "name": "Reve Stitching",
      "url": "https://revestitching.com",
      "logo": "https://revestitching.com/images/logo.svg",
      "description": "Leading 100% export-oriented knitted garment manufacturer based in Faisalabad, Pakistan.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Chak No. 196/R.B, Ghona Road",
        "addressLocality": "Faisalabad",
        "postalCode": "38000",
        "addressCountry": "PK"
      },
      "telephone": "+92-000-0000000",
      "email": "haroon@revestitching.com",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [],
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "SEDEX Compliance" },
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "ISO 9001:2015" }
      ]
    })} />

    <!-- View Transitions for smooth page-to-page navigation -->
    <ViewTransitions />
  </head>

  <body class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1" id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- ━━━ Global Script: GSAP + Lenis ━━━ -->
    <script>
      import { initAnimations } from '../scripts/animations.js';

      // Fires on initial load AND after each View Transition
      document.addEventListener('astro:page-load', () => {
        initAnimations();
      });
    </script>
  </body>
</html>