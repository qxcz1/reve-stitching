---
/**
 * src/layouts/Layout.astro
 * FIXED: Script initialization with proper error handling and visibility fallbacks.
 */

import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Reve Stitching — Leading 100% export-oriented knitted garment manufacturer in Faisalabad, Pakistan. 300K+ monthly capacity, SEDEX compliant, AQL 1.5-4.0.',
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Reve Stitching</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Reve Stitching`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Reve Stitching" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Reve Stitching`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Reve Stitching" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ManufacturingBusiness",
      "name": "Reve Stitching",
      "url": "https://revestitching.com",
      "description": "Leading 100% export-oriented knitted garment manufacturer based in Faisalabad, Pakistan.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Chak No. 196/R.B, Ghona Road",
        "addressLocality": "Faisalabad",
        "postalCode": "38000",
        "addressCountry": "PK"
      },
      "telephone": "+92-000-0000000",
      "email": "haroon@revestitching.com",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
        "opens": "08:00",
        "closes": "18:00"
      }
    })} />

    <ViewTransitions />
  </head>

  <body class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1" id="main-content">
      <slot />
    </main>

    <Footer />

    <ChatWidget />

    <!--
      ━━━ FIXED: Animation Script ━━━
      - Wrapped in try/catch
      - Falls back to making everything visible if GSAP fails
      - Uses astro:page-load for View Transitions compatibility
    -->
    <script>
      import { initAnimations } from '../scripts/animations.js';

      function safeInit() {
        try {
          initAnimations();
        } catch (e) {
          console.warn('Animation initialization failed:', e);
          // Fallback: make sure all content is visible
          document.querySelectorAll('[data-animate], [data-stagger] > *').forEach((el) => {
            (el as HTMLElement).style.opacity = '1';
            (el as HTMLElement).style.transform = 'none';
          });
        }
      }

      // Fires on initial load AND after each View Transition
      document.addEventListener('astro:page-load', safeInit);
    </script>

    <!--
      ━━━ CRITICAL FALLBACK ━━━
      If JavaScript completely fails to load/execute, this noscript-adjacent
      approach ensures content is always visible. This inline style runs
      before any external JS, guaranteeing visibility.
    -->
    <script is:inline>
      // If after 3 seconds the gsap-ready class hasn't been added,
      // force all animated elements to be visible
      setTimeout(function() {
        if (!document.documentElement.classList.contains('gsap-ready')) {
          var els = document.querySelectorAll('[data-animate], [data-stagger] > *');
          for (var i = 0; i < els.length; i++) {
            els[i].style.opacity = '1';
            els[i].style.transform = 'none';
          }
        }
      }, 3000);
    </script>
  </body>
</html>